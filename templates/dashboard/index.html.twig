{% extends 'base.html.twig' %}
{% block title %}Dashboard{% endblock %}

{% block page_subtitle %}
    {% if last_fetch %}dernier fetch · {{ last_fetch|date('d/m/Y H:i') }} · {% endif %}{{ app.user.userIdentifier }}
{% endblock %}

{% block header_actions %}
    {% if container_configured %}
        <span class="status-pill">
            <span class="dot{{ container_status == 'running' ? '' : ' dot--warning' }}"></span>
            navidrome · {{ container_label }}
        </span>
        <form method="post" action="{{ path('app_navidrome_container_start') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('navidrome_container') }}">
            <button type="submit" class="btn btn--success btn--sm">▷ démarrer</button>
        </form>
        <form method="post" action="{{ path('app_navidrome_container_stop') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('navidrome_container') }}">
            <button type="submit" class="btn btn--warning btn--sm">■ arrêter</button>
        </form>
    {% endif %}
{% endblock %}

{% block body %}
    {% set total_match = navidrome_matched + navidrome_unmatched %}
    {% set match_rate = total_match > 0 ? (navidrome_matched / total_match * 100) : null %}

    {# Rangée KPI #}
    <div class="grid grid--4">
        <div class="kpi">
            <div class="kpi__label">Scrobbles</div>
            <div class="kpi__value">{{ total_scrobbles|number_format(0, '.', ' ') }}</div>
            <div class="kpi__delta"><a href="{{ path('app_lastfm_import') }}" class="link">↧ importer</a></div>
        </div>

        <div class="kpi kpi--teal">
            <div class="kpi__label">Taux de match</div>
            {% if match_rate is not null %}
                <div class="kpi__value">{{ match_rate|number_format(1) }}<span class="unit">%</span></div>
                <div class="progress"><div class="progress__fill" style="width: {{ match_rate|number_format(1, '.', '') }}%"></div></div>
            {% else %}
                <div class="kpi__value">—</div>
            {% endif %}
        </div>

        <div class="kpi kpi--orange">
            <div class="kpi__label">Non-matchés</div>
            <div class="kpi__value">{{ navidrome_unmatched|number_format(0, '.', ' ') }}</div>
            {% if navidrome_unmatched > 0 %}<div class="kpi__delta"><a href="{{ path('app_navidrome_unmatched') }}" class="link">voir →</a></div>{% endif %}
        </div>

        <div class="kpi">
            <div class="kpi__label">En attente de sync</div>
            <div class="kpi__value">{{ navidrome_pending|number_format(0, '.', ' ') }}</div>
            {% if navidrome_pending > 0 %}<div class="kpi__delta"><a href="{{ path('app_navidrome_sync') }}" class="link">⇄ synchroniser</a></div>{% endif %}
        </div>
    </div>

    {% if strawberry_active %}
    <div class="grid grid--4">
        <div class="kpi">
            <div class="kpi__label">Strawberry · en attente</div>
            <div class="kpi__value kpi__value--sm">{{ (strawberry_pending ?? 0)|number_format(0, '.', ' ') }}</div>
            {% if strawberry_pending > 0 %}<div class="kpi__delta"><a href="{{ path('app_strawberry_sync') }}" class="link">⇄ synchroniser</a></div>{% endif %}
        </div>
        <div class="kpi kpi--orange">
            <div class="kpi__label">Strawberry · non-matchés</div>
            <div class="kpi__value kpi__value--sm">{{ (strawberry_unmatched ?? 0)|number_format(0, '.', ' ') }}</div>
            {% if strawberry_unmatched > 0 %}<div class="kpi__delta"><a href="{{ path('app_strawberry_unmatched') }}" class="link">voir →</a></div>{% endif %}
        </div>
    </div>
    {% endif %}

    {# Actions rapides + derniers runs #}
    <div class="grid grid--dash-runs">
        <div class="card">
            <div class="card__title card__title--sm">Actions rapides</div>
            <div class="grid grid--2" style="gap:10px;">
                <a href="{{ path('app_lastfm_import') }}" class="btn btn--ghost">↧ Import Last.fm</a>
                <a href="{{ path('app_navidrome_sync') }}" class="btn btn--ghost">⇄ Sync Navidrome</a>
                <a href="{{ path('app_stats') }}" class="btn btn--ghost">▤ Statistiques</a>
                <a href="{{ path('app_recommendations_index') }}" class="btn btn--ghost">✧ Recommandations</a>
            </div>
        </div>

        <div class="card" style="padding:0;">
            <div class="row between" style="padding:14px 16px; border-bottom:1px solid var(--border);">
                <div class="card__title card__title--sm mb-0">Derniers runs</div>
                <a href="{{ path('app_history') }}" class="link mono fs-12">voir tout →</a>
            </div>
            {% if recent_runs is empty %}
                <div class="empty-state" style="border:none;">Aucun run pour l'instant.</div>
            {% else %}
                <div class="divide" style="padding:4px 16px 10px;">
                    {% for run in recent_runs %}
                        <div class="run-row">
                            <span class="dot{{ run.status == 'success' ? '' : (run.status == 'error' ? ' dot--warning' : '') }}"></span>
                            <a href="{{ path('app_history_show', {id: run.id}) }}" class="name link">{{ run.label }}</a>
                            <span class="time">{{ run.startedAt|date('d/m H:i') }}{% if run.durationMs %} · {{ (run.durationMs / 1000)|number_format(1) }}s{% endif %}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
