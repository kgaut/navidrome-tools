{% extends 'base.html.twig' %}
{% block title %}Run #{{ run.id }}{% endblock %}

{% block page_subtitle %}<span class="mono">{{ run.type }}</span> · <span class="mono">{{ run.reference }}</span> · #{{ run.id }}{% endblock %}

{% block header_actions %}
    <span class="badge
        {%- if run.status == 'success' %} badge--success
        {%- elseif run.status == 'error' %} badge--warning
        {%- elseif run.status == 'running' %} badge--accent
        {%- else %} badge--neutral{% endif %}"
          {% if run.status == 'running' %}id="run-status"{% endif %}>
        {{ run.status }}
    </span>
    <a href="{{ path('app_history') }}" class="btn btn--outline btn--sm">← Historique</a>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card__title">{{ run.label }}</div>
        <div class="kv">
            <div class="kv__row"><span class="k">Lancé le</span><span class="v">{{ run.startedAt|date('d/m/Y H:i:s') }}</span></div>
            <div class="kv__row"><span class="k">Terminé le</span><span class="v">{{ run.finishedAt ? run.finishedAt|date('d/m/Y H:i:s') : '—' }}</span></div>
            <div class="kv__row"><span class="k">Durée</span><span class="v">{{ run.durationMs ? (run.durationMs / 1000)|number_format(2) ~ 's' : '—' }}</span></div>
        </div>
    </div>

    {% if run.message %}
    <div class="card">
        <div class="card__title card__title--sm t-orange">Message</div>
        <pre class="code-block">{{ run.message }}</pre>
    </div>
    {% endif %}

    {% if run.metrics %}
    <div class="card">
        <div class="card__title">Métriques</div>
        <div class="kv">
            {% for key, val in run.metrics %}
                <div class="kv__row"><span class="k">{{ key }}</span><span class="v">{{ val }}</span></div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% if run.status == 'running' %}
    <script>
        (function poll() {
            fetch('{{ path('app_history_status', {id: run.id}) }}')
                .then(r => r.json())
                .then(data => {
                    if (data.status !== 'running') {
                        window.location.reload();
                    } else {
                        setTimeout(poll, 2000);
                    }
                });
        })();
    </script>
    {% endif %}
{% endblock %}
