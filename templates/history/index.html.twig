{% extends 'base.html.twig' %}
{% block title %}Historique des runs{% endblock %}

{% block page_subtitle %}{{ total|number_format(0, '.', ' ') }} run{{ total != 1 ? 's' : '' }} · rétention 90 j{% endblock %}

{% block body %}
    <form method="get" class="filter-bar">
        <input type="text" name="type" value="{{ filters.type }}" placeholder="type · lastfm-fetch…" class="input">
        <select name="status" class="select" aria-label="Statut">
            <option value="">Tous statuts</option>
            <option value="success" {% if filters.status == 'success' %}selected{% endif %}>success</option>
            <option value="error" {% if filters.status == 'error' %}selected{% endif %}>error</option>
            <option value="running" {% if filters.status == 'running' %}selected{% endif %}>running</option>
        </select>
        <input type="text" name="q" value="{{ filters.q }}" placeholder="recherche · label…" class="input">
        <button type="submit" class="btn btn--primary btn--sm">Filtrer</button>
        <a href="{{ path('app_history') }}" class="btn btn--outline btn--sm">Réinitialiser</a>
    </form>

    {% if items is empty %}
        <div class="empty-state">Aucun run trouvé.</div>
    {% else %}
    <div class="card" style="padding:0; overflow:auto;">
        <table class="data-table data-table--in-card">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Label</th>
                    <th>Type</th>
                    <th>Statut</th>
                    <th class="num">Durée</th>
                    <th class="right">Lancé le</th>
                </tr>
            </thead>
            <tbody>
            {% for run in items %}
                <tr>
                    <td class="mono">{{ run.id }}</td>
                    <td>
                        <a href="{{ path('app_history_show', {id: run.id}) }}" class="link">{{ run.label }}</a>
                        {% if run.message %}<div class="cell-track__sub t-orange" style="max-width:32ch; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ run.message }}</div>{% endif %}
                    </td>
                    <td class="mono">{{ run.type }}</td>
                    <td>
                        <span class="badge
                            {%- if run.status == 'success' %} badge--success
                            {%- elseif run.status == 'error' %} badge--warning
                            {%- elseif run.status == 'running' %} badge--accent
                            {%- else %} badge--neutral{% endif %}">
                            {{ run.status }}
                        </span>
                    </td>
                    <td class="num">{% if run.durationMs %}{{ (run.durationMs / 1000)|number_format(1) }}s{% else %}—{% endif %}</td>
                    <td class="num">{{ run.startedAt|date('d/m/Y H:i:s') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pages > 1 %}
    <div class="pagination">
        {% if page > 1 %}<a href="{{ path('app_history', filters|merge({page: page - 1})) }}">← Préc.</a>{% endif %}
        <span class="current">{{ page }}</span>
        <span class="gap">/ {{ pages }}</span>
        {% if page < pages %}<a href="{{ path('app_history', filters|merge({page: page + 1})) }}">Suiv. →</a>{% endif %}
    </div>
    {% endif %}
    {% endif %}
{% endblock %}
