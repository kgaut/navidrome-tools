{% extends 'base.html.twig' %}
{% block title %}Connexion{% endblock %}
{% block body %}
<div class="max-w-sm mx-auto mt-16">
    <h1 class="text-2xl font-semibold mb-6 text-center">Navidrome Tools</h1>
    {% if error %}
        <div class="mb-4 p-3 rounded-sm bg-rose-50 border border-rose-300 text-rose-800 text-sm">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}
    <form method="post" class="bg-white shadow-sm rounded-sm p-6 space-y-4">
        <div>
            <label class="block text-xs uppercase text-slate-500 mb-1">Identifiant</label>
            <input type="text" name="_username" value="{{ last_username }}" autofocus
                   class="w-full border rounded-sm px-3 py-2 text-sm">
        </div>
        <div>
            <label class="block text-xs uppercase text-slate-500 mb-1">Mot de passe</label>
            <input type="password" name="_password" class="w-full border rounded-sm px-3 py-2 text-sm">
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit"
                class="w-full bg-slate-800 hover:bg-slate-900 text-white py-2 rounded-sm text-sm font-medium">
            Se connecter
        </button>
    </form>
</div>
{% endblock %}
