{% extends 'base.html.twig' %}
{% block title %}Top artistes — Last.fm{% endblock %}

{% block page_subtitle %}
    Top {{ top_n }} artistes par scrobbles sur la base outils.
    {% include '_top_source_indicator.html.twig' with { source: source, computed_at: computed_at, compute_command: compute_command } only %}
{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_lastfm_stats') }}" class="btn btn--outline btn--sm">← Stats Last.fm</a>
    <a href="{{ path('app_navidrome_top_artists') }}" class="btn btn--outline btn--sm">Voir côté Navidrome →</a>
{% endblock %}

{% block body %}
    {% include '_top_filter_form.html.twig' with { route: 'app_lastfm_top_artists' } only %}

    {% if rows is empty %}
        <div class="empty-state">Aucun scrobble pour ces filtres.</div>
    {% else %}
        {% set max_plays = rows|first.plays %}
        <div class="card" style="padding:0;">
            <table class="data-table data-table--in-card">
                <thead>
                    <tr>
                        <th class="right" style="width:48px;">#</th>
                        <th>Artiste</th>
                        <th class="num">Scrobbles</th>
                        <th>Premier</th>
                        <th>Dernier</th>
                        <th class="right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for row in rows %}
                    {% set lidarr = lidarr_artist_url(row.artist) %}
                    {% set lastfm = lastfm_artist_url(row.artist) %}
                    <tr>
                        <td class="num muted">{{ loop.index }}</td>
                        <td>
                            <span class="cell-track__title">{{ row.artist }}</span>
                            {% if lastfm %}<a href="{{ lastfm }}" target="_blank" rel="noopener" class="link mono fs-11" title="Last.fm artiste">[L]</a>{% endif %}
                        </td>
                        <td class="num">
                            {{ row.plays|number_format(0, '.', ' ') }}
                            <div class="bar-list__track mt-8">
                                <div class="bar-list__fill{{ loop.index is odd ? '' : '--alt' }}" style="width: {{ max_plays > 0 ? (row.plays / max_plays * 100) : 0 }}%"></div>
                            </div>
                        </td>
                        <td class="mono muted nowrap">{{ row.first_played_at ? row.first_played_at|date('d/m/Y H:i') : '—' }}</td>
                        <td class="mono muted nowrap">{{ row.last_played_at ? row.last_played_at|date('d/m/Y H:i') : '—' }}</td>
                        <td class="right nowrap">
                            {% if lidarr %}
                                <a href="{{ lidarr }}" target="_blank" rel="noopener" class="link mono fs-11" title="Chercher dans Lidarr">⇗ Lidarr</a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
