{% extends 'base.html.twig' %}

{% block title %}Import Last.fm{% endblock %}

{% block body %}
    <h1 class="text-2xl font-semibold mb-4">Import des scrobbles Last.fm</h1>

    <div class="bg-sky-50 border border-sky-300 text-sky-900 rounded-lg p-4 mb-6 text-sm">
        <div class="flex items-start gap-3">
            <div class="text-xl">ℹ️</div>
            <div class="flex-1">
                L'import Last.fm se fait en <strong>deux étapes découplées</strong> :
                <ol class="list-decimal pl-6 mt-1 space-y-0.5">
                    <li><strong>Récupération</strong> des scrobbles dans un buffer local — Navidrome peut tourner.</li>
                    <li><strong>Traitement</strong> du buffer : matching et insertion dans Navidrome — Navidrome doit être arrêté.</li>
                </ol>
                Cela évite tout risque de corruption SQLite et permet de fetcher
                régulièrement sans toucher à Navidrome.
            </div>
        </div>
    </div>

    {# ---------- Section 1 : Fetch ---------- #}
    <div class="bg-white shadow rounded p-6 max-w-2xl mb-6">
        <h2 class="text-lg font-semibold mb-1">1. Récupérer depuis Last.fm</h2>
        <p class="text-sm text-slate-500 mb-4">
            Lit l'historique Last.fm et stocke chaque scrobble dans le buffer local.
            Aucune écriture côté Navidrome — peut être lancé pendant que Navidrome tourne.
        </p>
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {{ form_row(form.lastfm_user) }}
                {{ form_row(form.api_key) }}
                {{ form_row(form.date_min) }}
                {{ form_row(form.date_max) }}
                {{ form_row(form.max_scrobbles) }}
            </div>
            <div class="border-t pt-4">
                {{ form_row(form.dry_run) }}
            </div>
            <div class="flex justify-end pt-2">
                <button type="submit"
                        class="px-4 py-2 text-sm rounded bg-emerald-600 hover:bg-emerald-700 text-white">
                    Lancer le fetch
                </button>
            </div>
        {{ form_end(form) }}
    </div>

    {# ---------- Section 2 : Process buffer ---------- #}
    <div class="bg-white shadow rounded p-6 max-w-2xl mb-6">
        <h2 class="text-lg font-semibold mb-1">2. Traiter le buffer</h2>
        <p class="text-sm text-slate-500 mb-3">
            <strong>{{ buffer_count|number_format(0, '.', ' ') }}</strong>
            scrobble{{ buffer_count > 1 ? 's' : '' }}
            en attente dans le buffer.
            {% if buffer_count == 0 %}
                Lancez d'abord un fetch ci-dessus.
            {% else %}
                Le traitement applique la cascade de matching, insère les scrobbles
                trouvés dans la table <code>scrobbles</code> de Navidrome, vide le
                buffer au fur et à mesure et persiste l'audit dans
                <code>lastfm_import_track</code>.
            {% endif %}
        </p>

        {% if container_configured and container_status == 'stopped' %}
            <div class="bg-emerald-50 border border-emerald-400 rounded p-3 mb-4 flex items-center gap-3 text-sm">
                <div class="text-xl">✅</div>
                <div class="flex-1 text-emerald-900">
                    Conteneur Navidrome <strong>arrêté</strong> — le traitement peut se lancer.
                </div>
                <form method="post" action="{{ path('app_navidrome_container_start') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('navidrome_container') }}">
                    <input type="hidden" name="_back" value="{{ path('app_lastfm_import') }}">
                    <button type="submit" class="text-xs px-2 py-1 rounded bg-emerald-700 hover:bg-emerald-800 text-white">
                        ▶ Redémarrer Navidrome
                    </button>
                </form>
            </div>
        {% elseif container_configured and container_status == 'running' %}
            <div class="bg-rose-50 border border-rose-400 rounded p-3 mb-4 text-sm">
                <div class="flex items-start gap-3">
                    <div class="text-xl">🛑</div>
                    <div class="flex-1 text-rose-900">
                        Navidrome tourne — le traitement est <strong>bloqué</strong>.
                        Arrêtez-le ci-dessous, lancez le traitement, puis redémarrez.
                        <div class="mt-2">
                            <form method="post" action="{{ path('app_navidrome_container_stop') }}"
                                  onsubmit="return confirm('Arrêter le conteneur Navidrome ?');"
                                  class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('navidrome_container') }}">
                                <input type="hidden" name="_back" value="{{ path('app_lastfm_import') }}">
                                <button type="submit" class="px-3 py-1 rounded bg-rose-600 hover:bg-rose-700 text-white text-sm">
                                    ⏸ Arrêter Navidrome
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="bg-amber-50 border border-amber-300 text-amber-900 rounded p-3 mb-4 text-sm">
                ⚠️ Vérifiez que <strong>Navidrome est bien arrêté</strong> avant
                de lancer le traitement (l'écriture concurrente sur la SQLite
                Navidrome peut corrompre le journal WAL).
                {% if container_configured and container_status == 'unknown' %}
                    <br>Statut conteneur indéterminé — vérifier que
                    <code>/var/run/docker.sock</code> est monté dans navidrome-tools.
                {% endif %}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_lastfm_process') }}"
              onsubmit="return confirm('Lancer le traitement des {{ buffer_count }} scrobbles bufferés ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('lastfm_process') }}">
            <button type="submit"
                    {% if buffer_count == 0 %}disabled{% endif %}
                    class="px-4 py-2 rounded text-sm text-white {{ buffer_count == 0 ? 'bg-slate-400 cursor-not-allowed' : 'bg-emerald-600 hover:bg-emerald-700' }}">
                ▶ Traiter le buffer
            </button>
        </form>
    </div>

    {# ---------- Cumulative rematch ---------- #}
    {% if unmatched_cumulative > 0 %}
        <div class="bg-white shadow rounded p-6 max-w-2xl mb-6">
            <h2 class="text-lg font-semibold mb-1">Re-tenter le matching cumulé</h2>
            <p class="text-sm text-slate-500 mb-3">
                <strong>{{ unmatched_cumulative|number_format(0, '.', ' ') }}</strong>
                scrobble{{ unmatched_cumulative > 1 ? 's' : '' }}
                non matché{{ unmatched_cumulative > 1 ? 's' : '' }} sur l'ensemble des imports passés.
                Re-tente avec les heuristiques courantes (utile après ajout de morceaux dans Navidrome,
                après création d'alias, ou après déploiement de nouvelles règles de matching).
            </p>
            <p class="text-xs text-rose-700 mb-3">
                ⚠️ Navidrome doit être <strong>arrêté</strong> avant de lancer le rematch.
            </p>
            <div class="flex flex-wrap items-center gap-3">
                <form method="post" action="{{ path('app_lastfm_rematch') }}"
                      onsubmit="return confirm('Lancer le rematch sur les {{ unmatched_cumulative }} scrobbles non matchés cumulés ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('lastfm_rematch') }}">
                    <button type="submit"
                            class="px-4 py-2 rounded bg-emerald-600 text-white text-sm hover:bg-emerald-700">
                        🔁 Re-tenter le matching de tous les unmatched
                    </button>
                </form>
                <a href="{{ path('app_lastfm_unmatched') }}"
                   class="text-sm text-sky-700 hover:underline">
                    Voir la liste détaillée →
                </a>
            </div>
        </div>
    {% endif %}

    {# ---------- Result ---------- #}
    {% if error %}
        <div class="bg-rose-50 border border-rose-300 text-rose-800 rounded p-4 mb-6">
            <strong>Erreur :</strong> {{ error }}
        </div>
    {% endif %}

    {% if report %}
        <div class="bg-white shadow rounded p-6 mb-6">
            <h2 class="font-semibold mb-3">Rapport de fetch</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-center">
                <div class="bg-slate-100 rounded p-3">
                    <div class="text-xs uppercase text-slate-500">Récupérés</div>
                    <div class="text-2xl font-semibold">{{ report.fetched|number_format(0, '.', ' ') }}</div>
                </div>
                <div class="bg-emerald-50 rounded p-3">
                    <div class="text-xs uppercase text-emerald-700">Bufferés</div>
                    <div class="text-2xl font-semibold text-emerald-800">{{ report.buffered|number_format(0, '.', ' ') }}</div>
                </div>
                <div class="bg-sky-50 rounded p-3">
                    <div class="text-xs uppercase text-sky-700">Déjà bufferés</div>
                    <div class="text-2xl font-semibold text-sky-800">{{ report.alreadyBuffered|number_format(0, '.', ' ') }}</div>
                </div>
            </div>
            {% if report.buffered > 0 %}
                <p class="text-sm text-slate-600 mt-3">
                    💡 Lancez ensuite le traitement du buffer (section 2) pour
                    matcher et insérer ces scrobbles dans Navidrome.
                </p>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
