{% extends 'base.html.twig' %}

{% block title %}Import Last.fm{% endblock %}

{% block body %}
    <h1 class="text-2xl font-semibold mb-4">Import des scrobbles Last.fm</h1>

    {# ---------- WARNING block: Navidrome must be stopped before write imports ---------- #}
    <div class="bg-rose-50 border-2 border-rose-400 rounded-lg p-5 mb-6 shadow-sm">
        <div class="flex items-start gap-3">
            <div class="text-3xl">⚠️</div>
            <div class="flex-1">
                <h2 class="text-lg font-bold text-rose-900 mb-1">
                    ARRÊTEZ NAVIDROME avant tout import qui écrit dans la base
                </h2>
                <p class="text-sm text-rose-900 mb-2">
                    Cet outil <strong>écrit directement</strong> dans le fichier
                    SQLite de Navidrome (table <code>scrobbles</code>). Si Navidrome
                    tourne en parallèle, vous risquez :
                </p>
                <ul class="text-sm text-rose-900 list-disc pl-6 space-y-1 mb-3">
                    <li>des <strong>locks SQLite</strong> qui font échouer l'import en cours de route ;</li>
                    <li>une <strong>corruption</strong> du journal WAL en cas d'écritures concurrentes ;</li>
                    <li>des stats incohérentes le temps que Navidrome rafraîchisse son cache.</li>
                </ul>
                <p class="text-sm text-rose-900 mb-2">
                    <strong>Procédure recommandée :</strong>
                </p>
                <ol class="text-sm text-rose-900 list-decimal pl-6 space-y-1 mb-3">
                    <li><strong>Sauvegardez</strong> votre fichier <code>navidrome.db</code> (cp navidrome.db navidrome.db.bak).</li>
                    <li>Cochez d'abord <strong>« Dry-run »</strong> pour vérifier le rapport des morceaux trouvés / non trouvés.</li>
                    <li>Stoppez Navidrome (<code>docker compose stop navidrome</code> ou systemctl stop).</li>
                    <li>Décochez « Dry-run » et relancez l'import.</li>
                    <li>Redémarrez Navidrome.</li>
                </ol>
                <p class="text-sm text-rose-900">
                    Pour de très gros historiques (&gt; 10 000 scrobbles), préférez la
                    commande CLI <code>php bin/console app:lastfm:import</code> sans
                    limite : aucun risque de timeout HTTP.
                </p>
            </div>
        </div>
    </div>

    {# ---------- Form ---------- #}
    <div class="bg-white shadow rounded p-6 max-w-2xl mb-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {{ form_row(form.lastfm_user) }}
                {{ form_row(form.api_key) }}
                {{ form_row(form.date_min) }}
                {{ form_row(form.date_max) }}
                {{ form_row(form.tolerance) }}
                {{ form_row(form.max_scrobbles) }}
            </div>
            <div class="border-t pt-4">
                {{ form_row(form.dry_run) }}
            </div>
            <div class="flex justify-end pt-2">
                <button type="submit"
                        onclick="if(!document.querySelector('[name$=\'[dry_run]\']').checked){return confirm('Avez-vous arrêté Navidrome ? Cliquez OK pour confirmer l\'import en écriture.');}"
                        class="px-4 py-2 text-sm rounded bg-emerald-600 hover:bg-emerald-700 text-white">
                    Lancer l'import
                </button>
            </div>
        {{ form_end(form) }}
    </div>

    {# ---------- Cumulative rematch ---------- #}
    {% if unmatched_cumulative > 0 %}
        <div class="bg-white shadow rounded p-6 max-w-2xl mb-6">
            <h2 class="text-lg font-semibold mb-1">Re-tenter le matching cumulé</h2>
            <p class="text-sm text-slate-500 mb-3">
                <strong>{{ unmatched_cumulative|number_format(0, '.', ' ') }}</strong>
                scrobble{{ unmatched_cumulative > 1 ? 's' : '' }}
                non matché{{ unmatched_cumulative > 1 ? 's' : '' }} sur l'ensemble des imports passés.
                Re-tente avec les heuristiques courantes (utile après ajout de morceaux dans Navidrome,
                après création d'alias, ou après déploiement de nouvelles règles de matching).
            </p>
            <p class="text-xs text-rose-700 mb-3">
                ⚠️ Navidrome doit être <strong>arrêté</strong> avant de lancer le rematch.
            </p>
            <div class="flex flex-wrap items-center gap-3">
                <form method="post" action="{{ path('app_lastfm_rematch') }}"
                      onsubmit="return confirm('Lancer le rematch sur les {{ unmatched_cumulative }} scrobbles non matchés cumulés ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('lastfm_rematch') }}">
                    <button type="submit"
                            class="px-4 py-2 rounded bg-emerald-600 text-white text-sm hover:bg-emerald-700">
                        🔁 Re-tenter le matching de tous les unmatched
                    </button>
                </form>
                <a href="{{ path('app_lastfm_unmatched') }}"
                   class="text-sm text-sky-700 hover:underline">
                    Voir la liste détaillée →
                </a>
            </div>
        </div>
    {% endif %}

    {# ---------- Result ---------- #}
    {% if error %}
        <div class="bg-rose-50 border border-rose-300 text-rose-800 rounded p-4 mb-6">
            <strong>Erreur :</strong> {{ error }}
        </div>
    {% endif %}

    {% if report %}
        <div class="bg-white shadow rounded p-6 mb-6">
            <h2 class="font-semibold mb-3">Rapport d'import</h2>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3 text-center">
                <div class="bg-slate-100 rounded p-3">
                    <div class="text-xs uppercase text-slate-500">Récupérés</div>
                    <div class="text-2xl font-semibold">{{ report.fetched|number_format(0, '.', ' ') }}</div>
                </div>
                <div class="bg-emerald-50 rounded p-3">
                    <div class="text-xs uppercase text-emerald-700">Insérés</div>
                    <div class="text-2xl font-semibold text-emerald-800">{{ report.inserted|number_format(0, '.', ' ') }}</div>
                </div>
                <div class="bg-sky-50 rounded p-3">
                    <div class="text-xs uppercase text-sky-700">Doublons</div>
                    <div class="text-2xl font-semibold text-sky-800">{{ report.duplicates|number_format(0, '.', ' ') }}</div>
                </div>
                <div class="bg-amber-50 rounded p-3">
                    <div class="text-xs uppercase text-amber-700">Non trouvés</div>
                    <div class="text-2xl font-semibold text-amber-800">{{ report.unmatched|number_format(0, '.', ' ') }}</div>
                </div>
                <div class="bg-indigo-50 rounded p-3" title="Scrobbles ignorés via un alias avec cible vide">
                    <div class="text-xs uppercase text-indigo-700">Ignorés</div>
                    <div class="text-2xl font-semibold text-indigo-800">{{ report.skipped|number_format(0, '.', ' ') }}</div>
                </div>
            </div>
        </div>

        {% if unmatched is not empty %}
            {% if not lidarr_configured %}
                <div class="bg-sky-50 border border-sky-300 text-sky-800 rounded p-3 text-sm mb-3">
                    💡 Configurez <code>LIDARR_URL</code> et <code>LIDARR_API_KEY</code> pour activer le bouton « + Lidarr » par ligne.
                </div>
            {% endif %}
            <div class="bg-white shadow rounded overflow-hidden">
                <div class="px-4 py-3 border-b bg-slate-50 flex items-center justify-between">
                    <h2 class="font-semibold text-sm">
                        Morceaux Last.fm non trouvés dans Navidrome
                        <span class="text-xs text-slate-500">
                            (top {{ unmatched|length }} sur {{ report.distinctUnmatched }} distincts, triés par scrobbles ↓)
                        </span>
                    </h2>
                </div>
                <div class="max-h-[600px] overflow-y-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-100 text-slate-600 text-left text-xs sticky top-0">
                        <tr>
                            <th class="px-3 py-2 w-20 text-right">Plays</th>
                            <th class="px-3 py-2">Artiste</th>
                            <th class="px-3 py-2">Titre</th>
                            <th class="px-3 py-2">Album</th>
                            <th class="px-3 py-2 w-64">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y">
                        {% for row in unmatched %}
                            <tr>
                                <td class="px-3 py-1.5 text-right font-medium">{{ row.count }}</td>
                                <td class="px-3 py-1.5">{{ row.artist }}</td>
                                <td class="px-3 py-1.5">{{ row.title }}</td>
                                <td class="px-3 py-1.5 text-slate-500">{{ row.album }}</td>
                                <td class="px-3 py-1.5">
                                    <div class="flex flex-wrap gap-1.5 items-center">
                                        <a href="{{ row.lastfm_url }}" target="_blank" rel="noopener"
                                           class="text-xs px-2 py-1 rounded bg-rose-100 text-rose-800 hover:bg-rose-200">
                                            Last.fm ↗
                                        </a>
                                        {% if row.navidrome_artist_id %}
                                            <a href="{{ navidrome_url }}/app/#/artist/{{ row.navidrome_artist_id }}/show"
                                               target="_blank" rel="noopener"
                                               class="text-xs px-2 py-1 rounded bg-sky-100 text-sky-800 hover:bg-sky-200">
                                                Navidrome ↗
                                            </a>
                                        {% endif %}
                                        {% if lidarr_configured %}
                                            <form method="post" action="{{ path('app_lidarr_add_artist') }}"
                                                  class="inline"
                                                  onsubmit="return confirm('Ajouter « {{ row.artist|e('js') }} » à Lidarr ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('lidarr_add') }}">
                                                <input type="hidden" name="artist" value="{{ row.artist }}">
                                                <button type="submit"
                                                        class="text-xs px-2 py-1 rounded bg-emerald-600 hover:bg-emerald-700 text-white">
                                                    + Lidarr
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <p class="text-xs text-slate-500 px-4 py-2 border-t">
                    Ces morceaux ont été scrobblés sur Last.fm mais n'existent pas
                    dans votre lib Navidrome (ou ont un artiste/titre différent).
                    Ajoutez-les puis relancez l'import.
                </p>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
