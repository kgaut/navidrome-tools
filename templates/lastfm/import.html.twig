{% extends 'base.html.twig' %}
{% block title %}Import Last.fm{% endblock %}

{% block page_subtitle %}fetch de l'historique · table locale scrobbles{% endblock %}

{% block body %}
    <div class="banner banner--info">
        Les scrobbles sont importés dans la table locale <span class="mono">scrobbles</span> (source de vérité).
        Le worker Messenger traite les messages en arrière-plan — suivez la progression dans
        <a href="{{ path('app_history') }}" class="link">l'historique</a>.
    </div>

    <div class="grid grid--sidebar-main">
        {# Carte gauche : fetch #}
        <div class="card">
            <div class="card__title">Lancer un fetch</div>
            <form method="post" action="{{ path('app_lastfm_import_post') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('lastfm_fetch') }}">

                <div class="field mb-12">
                    <label>Utilisateur Last.fm *</label>
                    <input type="text" name="user" value="{{ default_user }}" required class="input">
                </div>

                <div class="field mb-12">
                    <label>API Key *</label>
                    <input type="text" name="api_key" value="{{ default_api_key }}" required class="input">
                </div>

                <div class="row gap-16 mb-12">
                    <div class="field" style="flex:1;">
                        <label>Depuis (date-min)</label>
                        <input type="date" name="date_min" class="input">
                        <span class="muted fs-11">Vide = smart date (depuis le dernier fetch)</span>
                    </div>
                    <div class="field" style="flex:1;">
                        <label>Jusqu'à (date-max)</label>
                        <input type="date" name="date_max" class="input">
                    </div>
                </div>

                <div class="row gap-16 mb-12">
                    <div class="field">
                        <label>Max scrobbles</label>
                        <input type="number" name="max_scrobbles" min="1" placeholder="∞" class="input" style="width:120px;">
                    </div>
                    <label class="checkbox" style="align-self:flex-end;">
                        <input type="checkbox" name="dry_run" value="1"> --dry-run (ne pas écrire en DB)
                    </label>
                </div>

                <button type="submit" class="btn btn--primary btn--block">↧ Lancer le fetch</button>
            </form>

            <div class="muted mono fs-12 mt-12">
                CLI : <span class="t-3">php bin/console app:lastfm:fetch [user] [--date-min=YYYY-MM-DD] [--date-max=YYYY-MM-DD] [--dry-run]</span>
            </div>
        </div>

        {# Carte droite : dernier import #}
        <div class="card">
            <div class="card__title">Dernier import</div>
            <div class="kv">
                <div class="kv__row">
                    <span class="k">Statut</span>
                    <span class="v">
                        {% if last_fetch %}
                            <span class="dot"></span> terminé
                        {% else %}
                            <span class="dot dot--warning"></span> jamais
                        {% endif %}
                    </span>
                </div>
                <div class="kv__row"><span class="k">Scrobbles locaux</span><span class="v">{{ total_scrobbles|number_format(0, '.', ' ') }}</span></div>
                {% if user_scrobbles is not null %}
                <div class="kv__row"><span class="k">Scrobbles de {{ default_user }}</span><span class="v">{{ user_scrobbles|number_format(0, '.', ' ') }}</span></div>
                {% endif %}
                <div class="kv__row">
                    <span class="k">Quand</span>
                    <span class="v">{% if last_fetch %}{{ last_fetch|date('d/m/Y H:i') }}{% else %}—{% endif %}</span>
                </div>
            </div>

            {% if last_fetch %}
                <div class="progress"><div class="progress__fill" style="width:100%"></div></div>
            {% else %}
                <div class="banner banner--warning mt-12">Premier import — récupération de l'historique complet.</div>
            {% endif %}
        </div>
    </div>
{% endblock %}
