{% extends 'base.html.twig' %}

{% block title %}Import Last.fm{% endblock %}

{% block body %}
    <h1 class="text-2xl font-semibold mb-4">Import des scrobbles Last.fm</h1>

    <div class="bg-sky-50 border border-sky-300 text-sky-900 rounded-lg p-4 mb-6 text-sm">
        <div class="flex items-start gap-3">
            <div class="text-xl">ℹ️</div>
            <div class="flex-1">
                L'import Last.fm se fait en <strong>deux étapes découplées</strong>, lancées
                exclusivement en CLI :
                <ol class="list-decimal pl-6 mt-1 space-y-0.5">
                    <li><strong>Récupération</strong> des scrobbles dans un buffer local — Navidrome peut tourner.</li>
                    <li><strong>Traitement</strong> du buffer : matching et insertion dans Navidrome — Navidrome doit être arrêté.</li>
                </ol>
                Cette page affiche l'état du buffer et les commandes à copier-coller.
                Les jobs s'exécutent depuis le crontab unix de l'hôte (ou à la main).
                Si Strawberry est configuré, une <strong>étape 3</strong> supplémentaire
                met à jour les playcounts dans sa base de données.
            </div>
        </div>
    </div>

    {# ---------- État ---------- #}
    <div class="bg-white shadow-sm rounded-sm p-6 max-w-3xl mb-6">
        <h2 class="text-lg font-semibold mb-3">État</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div class="bg-slate-50 rounded-sm p-3">
                <div class="text-xs uppercase text-slate-500">En attente → Navidrome</div>
                <div class="text-2xl font-semibold">{{ buffer_count|number_format(0, '.', ' ') }}</div>
                <div class="text-xs text-slate-500 mt-1">
                    scrobble{{ buffer_count > 1 ? 's' : '' }} non encore traité{{ buffer_count > 1 ? 's' : '' }} pour Navidrome
                </div>
            </div>
            {% if strawberry_configured %}
            <div class="bg-slate-50 rounded-sm p-3">
                <div class="text-xs uppercase text-slate-500">Strawberry — en attente</div>
                <div class="text-2xl font-semibold">{{ buffer_pending_strawberry|number_format(0, '.', ' ') }}</div>
                <div class="text-xs text-slate-500 mt-1">scrobble{{ buffer_pending_strawberry != 1 ? 's' : '' }} jamais tentés</div>
            </div>
            {% if buffer_unmatched_strawberry > 0 %}
            <div class="bg-slate-50 rounded-sm p-3">
                <div class="text-xs uppercase text-slate-500">Strawberry — non matchés</div>
                <div class="text-2xl font-semibold">{{ buffer_unmatched_strawberry|number_format(0, '.', ' ') }}</div>
                <div class="text-xs text-slate-500 mt-1">
                    <a href="{{ path('app_strawberry_unmatched') }}" class="text-sky-700 hover:underline">détails</a>
                </div>
            </div>
            {% endif %}
            {% endif %}
            <div class="bg-slate-50 rounded-sm p-3">
                <div class="text-xs uppercase text-slate-500">Non matchés cumulés</div>
                <div class="text-2xl font-semibold">{{ unmatched_cumulative|number_format(0, '.', ' ') }}</div>
                <div class="text-xs text-slate-500 mt-1">
                    sur l'ensemble des imports passés —
                    <a href="{{ path('app_lastfm_unmatched') }}" class="text-sky-700 hover:underline">détails</a>
                </div>
            </div>
        </div>

        {% if container_configured %}
            <div class="mt-3 text-xs text-slate-500">
                Conteneur Navidrome :
                {% if container_status == 'running' %}
                    <span class="text-emerald-700 font-mono">running</span>
                {% elseif container_status == 'stopped' %}
                    <span class="text-amber-700 font-mono">stopped</span>
                {% else %}
                    <span class="text-rose-700 font-mono">{{ container_status }}</span>
                {% endif %}
                — gestion sur la card du dashboard.
            </div>
        {% endif %}
    </div>

    {# ---------- 1. Fetch ---------- #}
    <div class="bg-white shadow-sm rounded-sm p-6 max-w-3xl mb-6">
        <h2 class="text-lg font-semibold mb-1">1. Récupérer depuis Last.fm</h2>
        <p class="text-sm text-slate-500 mb-3">
            Lit l'historique Last.fm et stocke chaque scrobble dans le buffer local.
            <strong>Aucune écriture côté Navidrome</strong> — peut tourner pendant que Navidrome est up.
            Idempotent grâce à la unique constraint <code>(lastfm_user, played_at, artist, title)</code>.
        </p>

        <div class="text-xs uppercase text-slate-500 mt-2 mb-1">Localement (Symfony serve / Docker)</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto mb-2"><code>php bin/console app:lastfm:import{% if default_lastfm_user %} {{ default_lastfm_user }}{% else %} USERNAME{% endif %} \
    [--api-key=KEY] [--date-min=YYYY-MM-DD] [--date-max=YYYY-MM-DD] \
    [--max-scrobbles=N] [--dry-run]</code></pre>

        <div class="text-xs uppercase text-slate-500 mt-3 mb-1">Docker Compose</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto mb-2"><code>docker compose exec -T navidrome-tools-web \
    php bin/console app:lastfm:import{% if default_lastfm_user %} {{ default_lastfm_user }}{% else %} USERNAME{% endif %}</code></pre>

        <div class="text-xs uppercase text-slate-500 mt-3 mb-1">Lando (dev)</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto"><code>lando symfony app:lastfm:import{% if default_lastfm_user %} {{ default_lastfm_user }}{% else %} USERNAME{% endif %}</code></pre>

        <p class="text-xs text-slate-500 mt-3">
            <code>LASTFM_USER</code> et <code>LASTFM_API_KEY</code> servent de défaut quand les options ne sont pas fournies.
        </p>
    </div>

    {# ---------- 2. Process ---------- #}
    <div class="bg-white shadow-sm rounded-sm p-6 max-w-3xl mb-6">
        <h2 class="text-lg font-semibold mb-1">2. Traiter le buffer</h2>
        <p class="text-sm text-slate-500 mb-3">
            Stream du buffer (par <code>played_at</code> ASC), cascade de matching, insertion dans la table
            <code>scrobbles</code> de Navidrome, audit dans <code>lastfm_import_track</code>,
            puis marquage <code>synced_navidrome = true</code> (les rows sont conservées — le buffer est
            un log permanent). <strong>Navidrome doit être arrêté</strong>
            pour éviter toute corruption SQLite.
        </p>
        <p class="text-xs text-rose-700 mb-3">
            Avec <code>--auto-stop</code>, l'arrêt et le redémarrage du conteneur Navidrome sont orchestrés
            automatiquement (snapshot SQLite + <code>PRAGMA quick_check</code> avant chaque écriture).
        </p>

        <div class="text-xs uppercase text-slate-500 mt-2 mb-1">Localement</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto mb-2"><code>php bin/console app:lastfm:process --auto-stop \
    [--limit=N] [--tolerance=60] [--dry-run]</code></pre>

        <div class="text-xs uppercase text-slate-500 mt-3 mb-1">Docker Compose (cron)</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto mb-2"><code>docker compose exec -T navidrome-tools-web \
    php bin/console app:lastfm:process --auto-stop</code></pre>

        <div class="text-xs uppercase text-slate-500 mt-3 mb-1">Lando (dev)</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto"><code>lando symfony app:lastfm:process --auto-stop</code></pre>

        <p class="text-xs text-slate-500 mt-3">
            Sans <code>--auto-stop</code>, la commande échoue si Navidrome tourne (pré-flight).
            Passez <code>-f</code> pour outrepasser à vos risques.
        </p>
    </div>

    {# ---------- 3. Strawberry ---------- #}
    <div class="bg-white shadow-sm rounded-sm p-6 max-w-3xl mb-6">
        <h2 class="text-lg font-semibold mb-1">{{ strawberry_configured ? '3' : '3' }}. Synchroniser vers Strawberry</h2>
        <p class="text-sm text-slate-500 mb-3">
            Incrémente <code>playcount</code> et met à jour <code>lastplayed</code> dans la base
            Strawberry pour chaque scrobble non encore synchronisé. Navidrome peut rester up.
            Les morceaux non trouvés sont retentés automatiquement au prochain run.
        </p>

        {# --- Sous-section A : volume monté (STRAWBERRY_DB_PATH configuré) --- #}
        {% if strawberry_configured %}
        <div class="bg-slate-50 border border-slate-200 rounded-sm p-3 mb-4">
            <div class="text-xs font-semibold uppercase text-slate-500 mb-2">Via volume monté (STRAWBERRY_DB_PATH)</div>
            {% if buffer_unsynced_strawberry is not null %}
            <p class="text-sm text-slate-600 mb-2">
                {{ buffer_unsynced_strawberry }} scrobble{{ buffer_unsynced_strawberry != 1 ? 's' : '' }} en attente de sync.
            </p>
            {% endif %}
            <div class="text-xs uppercase text-slate-500 mt-2 mb-1">Localement / Docker Compose</div>
            <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto"><code>php bin/console app:strawberry:process [--limit=N] [--dry-run] [--retry-unmatched]
docker compose exec -T navidrome-tools-web php bin/console app:strawberry:process</code></pre>
            {% if buffer_unmatched_strawberry is defined and buffer_unmatched_strawberry > 0 %}
            <p class="text-xs text-rose-600 mt-2">
                {{ buffer_unmatched_strawberry }} scrobble{{ buffer_unmatched_strawberry != 1 ? 's' : '' }} non matchés —
                <a href="{{ path('app_strawberry_unmatched') }}" class="underline">voir</a>
                ou lancer avec <code>--retry-unmatched</code> après ajout dans Strawberry.
            </p>
            {% endif %}
        </div>
        {% endif %}

        {# --- Sous-section B : upload/download --- #}
        <div class="border border-slate-200 rounded-sm p-3">
            <div class="text-xs font-semibold uppercase text-slate-500 mb-2">Via upload (Strawberry sur une autre machine)</div>

            {# Fichier actuellement uploadé #}
            {% if strawberry_upload_info %}
            <div class="bg-emerald-50 border border-emerald-200 rounded-sm p-3 mb-3 text-sm">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <span class="font-medium">strawberry.db</span>
                        — {{ (strawberry_upload_info.size / 1024 / 1024)|number_format(1) }} Mo
                        — uploadé le {{ strawberry_upload_info.mtime|date('d/m/Y H:i') }}
                        {% if strawberry_upload_unsynced is not null %}
                        — <span class="{{ strawberry_upload_unsynced == 0 ? 'text-emerald-700' : 'text-amber-700' }}">
                            {{ strawberry_upload_unsynced }} en attente
                        </span>
                        {% endif %}
                        {% if strawberry_upload_unmatched is not null and strawberry_upload_unmatched > 0 %}
                        — <a href="{{ path('app_strawberry_unmatched') }}"
                             class="text-rose-600 hover:underline">
                            {{ strawberry_upload_unmatched }} non matché{{ strawberry_upload_unmatched != 1 ? 's' : '' }}
                        </a>
                        {% endif %}
                    </div>
                    <div class="flex gap-2 shrink-0">
                        <a href="{{ path('app_strawberry_download') }}"
                           class="text-xs bg-sky-600 hover:bg-sky-700 text-white px-3 py-1 rounded-sm">
                            ⬇ Télécharger
                        </a>
                        <form method="post" action="{{ path('app_strawberry_delete_upload') }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('strawberry_delete_upload') }}">
                            <button type="submit"
                                    onclick="return confirm('Supprimer le fichier uploadé ?')"
                                    class="text-xs bg-rose-600 hover:bg-rose-700 text-white px-3 py-1 rounded-sm">
                                ✕ Supprimer
                            </button>
                        </form>
                    </div>
                </div>

                {# Bouton process #}
                <form method="post" action="{{ path('app_strawberry_process') }}" class="mt-3 flex flex-wrap gap-3 items-center">
                    <input type="hidden" name="_token" value="{{ csrf_token('strawberry_process') }}">
                    <button type="submit" name="retry_unmatched" value="0"
                            class="text-sm bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-sm font-medium">
                        ▶ Synchroniser (nouveaux)
                    </button>
                    {% if strawberry_upload_unmatched is not null and strawberry_upload_unmatched > 0 %}
                    <button type="submit" name="retry_unmatched" value="1"
                            class="text-sm bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-sm font-medium">
                        ↺ Retry {{ strawberry_upload_unmatched }} non matchés
                    </button>
                    {% endif %}
                    <span class="text-xs text-slate-400">Traitement synchrone.</span>
                </form>

                <div class="text-xs text-slate-400 mt-2">
                    Ou en CLI :
                    <code>php bin/console app:strawberry:process --db-path=var/strawberry_upload/strawberry.db [--retry-unmatched]</code>
                </div>
            </div>
            {% endif %}

            {# Formulaire d'upload #}
            <form method="post" action="{{ path('app_strawberry_upload') }}" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('strawberry_upload') }}">
                <div class="flex items-center gap-3">
                    <input type="file" name="db_file" accept=".db"
                           class="text-sm text-slate-600 file:mr-3 file:py-1 file:px-3 file:rounded-sm file:border-0
                                  file:text-xs file:font-medium file:bg-slate-100 file:text-slate-700
                                  hover:file:bg-slate-200">
                    <button type="submit"
                            class="text-sm bg-slate-700 hover:bg-slate-800 text-white px-4 py-1.5 rounded-sm shrink-0">
                        ⬆ Uploader strawberry.db
                    </button>
                </div>
            </form>
            <p class="text-xs text-slate-400 mt-2">
                Fichier SQLite de Strawberry, typiquement
                <code>~/.local/share/strawberry/strawberry/strawberry.db</code>.
                Taille max : 200 Mo (configurable via <code>upload_max_filesize</code> dans
                <code>docker/php.ini</code>).
            </p>
        </div>
    </div>

    {# ---------- 4. Rematch ---------- #}
    <div class="bg-white shadow-sm rounded-sm p-6 max-w-3xl mb-6">
        <h2 class="text-lg font-semibold mb-1">{{ strawberry_configured ? '4' : '3' }}. Re-matcher les unmatched</h2>
        <p class="text-sm text-slate-500 mb-3">
            Ré-applique la cascade de matching aux rows <code>lastfm_import_track</code> en status
            <em>unmatched</em>. Utile après ajout de morceaux dans Navidrome, après création d'alias,
            ou après déploiement de nouvelles heuristiques. <strong>Navidrome doit être arrêté</strong>
            (mêmes contraintes que le process).
        </p>

        <div class="text-xs uppercase text-slate-500 mt-2 mb-1">Tous les unmatched cumulés</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto mb-2"><code>php bin/console app:lastfm:rematch --auto-stop \
    [--limit=N] [--tolerance=60] [--random] [--dry-run]</code></pre>

        <div class="text-xs uppercase text-slate-500 mt-3 mb-1">Limiter à un run précis</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto mb-2"><code>php bin/console app:lastfm:rematch --auto-stop --run-id=&lt;ID&gt;</code></pre>

        <div class="text-xs uppercase text-slate-500 mt-3 mb-1">Docker Compose / Lando</div>
        <pre class="bg-slate-900 text-slate-100 rounded-sm px-3 py-2 text-xs overflow-x-auto"><code>docker compose exec -T navidrome-tools-web \
    php bin/console app:lastfm:rematch --auto-stop

lando symfony app:lastfm:rematch --auto-stop</code></pre>
    </div>

    <div class="text-sm text-slate-500 max-w-3xl">
        Voir l'<a href="{{ path('app_history') }}" class="text-sky-700 hover:underline">historique des runs</a>
        pour le détail des derniers imports (status, durée, métriques, erreurs).
    </div>
{% endblock %}
