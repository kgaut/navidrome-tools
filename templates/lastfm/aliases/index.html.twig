{% extends 'base.html.twig' %}

{% block title %}Alias{% endblock %}

{% block page_subtitle %}{{ total|number_format(0, '.', ' ') }} alias piste · consultés avant toutes les heuristiques de matching{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_lastfm_alias_new') }}" class="btn btn--primary btn--sm">+ Nouvel alias</a>
{% endblock %}

{% block body %}
    <div class="tabs">
        <a href="{{ path('app_lastfm_alias_index') }}" class="tab tab--active">Alias piste</a>
        <a href="{{ path('app_lastfm_artist_alias_index') }}" class="tab">Alias artiste</a>
    </div>

    <div class="card" style="border-radius:0 var(--r-card) var(--r-card) var(--r-card);">
        <form method="get" class="row" style="margin-bottom:14px;">
            <input type="search" name="q" value="{{ filters.q }}" placeholder="Filtrer par artiste ou titre source…"
                   class="input" style="flex:1; min-width:200px;">
            <button type="submit" class="btn btn--primary btn--sm">Filtrer</button>
            <a href="{{ path('app_lastfm_alias_index') }}" class="btn btn--outline btn--sm">Réinitialiser</a>
        </form>

        {% if aliases is empty %}
            <div class="empty-state">
                {% if filters.q %}
                    Aucun alias ne correspond à « {{ filters.q }} ».
                {% else %}
                    Aucun alias défini pour l'instant. Cliquez « + Nouvel alias » ou utilisez le bouton « ✎ Mapper »
                    à côté d'un scrobble non matché dans le détail d'un import Last.fm.
                {% endif %}
            </div>
        {% else %}
            <table class="data-table data-table--in-card">
                <thead>
                <tr>
                    <th>Source (artiste)</th>
                    <th>Source (titre)</th>
                    <th>Cible</th>
                    <th>Créé le</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for alias in aliases %}
                    <tr>
                        <td>{{ alias.sourceArtist }}</td>
                        <td>{{ alias.sourceTitle }}</td>
                        <td class="mono">
                            {% if alias.skip %}
                                <span class="badge badge--warning">IGNORÉ</span>
                            {% else %}
                                {{ alias.targetMediaFileId }}
                            {% endif %}
                        </td>
                        <td class="mono">{{ alias.createdAt|date('Y-m-d H:i') }}</td>
                        <td class="right nowrap">
                            <a href="{{ path('app_lastfm_alias_edit', {id: alias.id}) }}" class="link" title="Modifier">✎</a>
                            <form method="post" action="{{ path('app_lastfm_alias_delete', {id: alias.id}) }}"
                                  style="display:inline-block; margin-left:10px;"
                                  onsubmit="return confirm('Supprimer cet alias ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-alias-' ~ alias.id) }}">
                                <button type="submit" class="btn btn--ghost btn--sm" title="Supprimer">✕</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    {% if total_pages > 1 %}
        <div class="pagination">
            {% if page > 1 %}
                <a href="{{ path('app_lastfm_alias_index', filters|merge({page: page - 1})) }}">‹ Précédent</a>
            {% endif %}
            <span class="current">{{ page }}</span>
            <span>/ {{ total_pages }}</span>
            {% if page < total_pages %}
                <a href="{{ path('app_lastfm_alias_index', filters|merge({page: page + 1})) }}">Suivant ›</a>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
