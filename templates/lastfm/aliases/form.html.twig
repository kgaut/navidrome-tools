{% extends 'base.html.twig' %}

{% block title %}{{ alias ? 'Modifier alias' : 'Nouvel alias' }}{% endblock %}

{% block page_subtitle %}Forcer la résolution d'une paire (artiste, titre) Last.fm vers un media_file Navidrome{% endblock %}

{% block body %}
    <div>
        <a href="{{ path('app_lastfm_alias_index') }}" class="link mono">← Retour à la liste des alias</a>
    </div>

    <div class="card" style="max-width:640px;">
        {{ form_start(form) }}
            <div class="col" style="gap:16px;">
                <div class="field">
                    {{ form_label(form.source_artist) }}
                    {{ form_widget(form.source_artist, {attr: {class: 'input'}}) }}
                    <span class="muted fs-11">{{ form_help(form.source_artist) }}</span>
                    {{ form_errors(form.source_artist) }}
                </div>
                <div class="field">
                    {{ form_label(form.source_title) }}
                    {{ form_widget(form.source_title, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.source_title) }}
                </div>

                <div style="border-top:1px solid var(--border); padding-top:16px;">
                    <label class="checkbox">
                        {{ form_widget(form.skip) }}
                        <span>{{ form.skip.vars.label }}</span>
                    </label>
                    <p class="muted fs-11" style="margin:6px 0 0 22px;">{{ form_help(form.skip) }}</p>
                </div>

                <div class="field">
                    {{ form_label(form.target_media_file_id) }}
                    {{ form_widget(form.target_media_file_id, {attr: {class: 'input mono'}}) }}
                    <span class="muted fs-11">{{ form_help(form.target_media_file_id) }}</span>
                    {{ form_errors(form.target_media_file_id) }}
                </div>
            </div>

            <div class="row" style="margin-top:20px;">
                <button type="submit" class="btn btn--primary">
                    {{ alias ? 'Enregistrer les modifications' : 'Créer l\'alias' }}
                </button>
                <a href="{{ path('app_lastfm_alias_index') }}" class="btn btn--outline">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
