{% extends 'base.html.twig' %}

{% block title %}{{ alias ? 'Modifier alias artiste' : 'Nouvel alias artiste' }}{% endblock %}

{% block page_subtitle %}Réécrit le nom d'artiste source en nom canonique avant la cascade de matching{% endblock %}

{% block body %}
    <div>
        <a href="{{ path('app_lastfm_artist_alias_index') }}" class="link mono">← Retour à la liste des alias artistes</a>
    </div>

    <div class="card" style="max-width:640px;">
        <p class="muted fs-12 mb-12">
            Un seul alias couvre tous les morceaux de l'artiste — utile pour les renommages
            (« La Ruda Salska » → « La Ruda »), les variantes de romanisation, ou les conventions « The X » / « X, The ».
        </p>

        {{ form_start(form) }}
            <div class="col" style="gap:16px;">
                <div class="field">
                    {{ form_label(form.source_artist) }}
                    {{ form_widget(form.source_artist, {attr: {class: 'input'}}) }}
                    <span class="muted fs-11">{{ form_help(form.source_artist) }}</span>
                    {{ form_errors(form.source_artist) }}
                </div>
                <div class="field">
                    {{ form_label(form.target_artist) }}
                    {{ form_widget(form.target_artist, {attr: {class: 'input'}}) }}
                    <span class="muted fs-11">{{ form_help(form.target_artist) }}</span>
                    {{ form_errors(form.target_artist) }}
                </div>
            </div>

            <div class="row" style="margin-top:20px;">
                <button type="submit" class="btn btn--primary">
                    {{ alias ? 'Enregistrer les modifications' : 'Créer l\'alias artiste' }}
                </button>
                <a href="{{ path('app_lastfm_artist_alias_index') }}" class="btn btn--outline">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
