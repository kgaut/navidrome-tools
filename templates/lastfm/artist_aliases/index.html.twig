{% extends 'base.html.twig' %}

{% block title %}Alias{% endblock %}

{% block page_subtitle %}{{ total|number_format(0, '.', ' ') }} alias artiste · réécrit le nom d'artiste avant la cascade de matching{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_lastfm_artist_alias_new') }}" class="btn btn--primary btn--sm">+ Nouvel alias artiste</a>
{% endblock %}

{% block body %}
    <div class="tabs">
        <a href="{{ path('app_lastfm_alias_index') }}" class="tab">Alias piste</a>
        <a href="{{ path('app_lastfm_artist_alias_index') }}" class="tab tab--active">Alias artiste</a>
    </div>

    <div class="card" style="border-radius:0 var(--r-card) var(--r-card) var(--r-card);">
        <p class="muted mono fs-12 mb-12">
            Un seul alias couvre tous les morceaux. Pour mapper un track précis vers un media_file, utilisez les
            <a href="{{ path('app_lastfm_alias_index') }}" class="link">alias track-level</a>.
        </p>

        <form method="get" class="row" style="margin-bottom:14px;">
            <input type="search" name="q" value="{{ filters.q }}" placeholder="Filtrer par artiste source ou cible…"
                   class="input" style="flex:1; min-width:200px;">
            <button type="submit" class="btn btn--primary btn--sm">Filtrer</button>
            <a href="{{ path('app_lastfm_artist_alias_index') }}" class="btn btn--outline btn--sm">Réinitialiser</a>
        </form>

        {% if aliases is empty %}
            <div class="empty-state">
                {% if filters.q %}
                    Aucun alias artiste ne correspond à « {{ filters.q }} ».
                {% else %}
                    Aucun alias artiste défini pour l'instant. Cliquez « + Nouvel alias artiste » ou utilisez le bouton
                    « ✎ Aliaser l'artiste » sur la page <a href="{{ path('app_navidrome_unmatched') }}" class="link">Non-matchés</a>.
                {% endif %}
            </div>
        {% else %}
            <table class="data-table data-table--in-card">
                <thead>
                <tr>
                    <th>Artiste source (Last.fm)</th>
                    <th>Artiste cible (Navidrome)</th>
                    <th>Créé le</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for alias in aliases %}
                    <tr>
                        <td>{{ alias.sourceArtist }}</td>
                        <td>{{ alias.targetArtist }}</td>
                        <td class="mono">{{ alias.createdAt|date('Y-m-d H:i') }}</td>
                        <td class="right nowrap">
                            <a href="{{ path('app_lastfm_artist_alias_edit', {id: alias.id}) }}" class="link" title="Modifier">✎</a>
                            <form method="post" action="{{ path('app_lastfm_artist_alias_delete', {id: alias.id}) }}"
                                  style="display:inline-block; margin-left:10px;"
                                  onsubmit="return confirm('Supprimer cet alias artiste ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-artist-alias-' ~ alias.id) }}">
                                <button type="submit" class="btn btn--ghost btn--sm" title="Supprimer">✕</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    {% if total_pages > 1 %}
        <div class="pagination">
            {% if page > 1 %}
                <a href="{{ path('app_lastfm_artist_alias_index', filters|merge({page: page - 1})) }}">‹ Précédent</a>
            {% endif %}
            <span class="current">{{ page }}</span>
            <span>/ {{ total_pages }}</span>
            {% if page < total_pages %}
                <a href="{{ path('app_lastfm_artist_alias_index', filters|merge({page: page + 1})) }}">Suivant ›</a>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
