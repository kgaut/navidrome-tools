{% extends 'base.html.twig' %}
{% block title %}Sync Strawberry{% endblock %}

{% block page_subtitle %}playcount · lastplayed · compteurs agrégés{% endblock %}

{% block body %}
    <div class="banner banner--info">
        Strawberry stocke les écoutes en <strong>compteurs agrégés</strong> (<span class="mono">playcount</span> +
        <span class="mono">lastplayed</span>). Navidrome peut rester up pendant cette synchronisation.
    </div>

    {# Compteurs #}
    <div class="grid grid--3">
        <div class="kpi kpi--teal">
            <div class="kpi__label">En attente</div>
            <div class="kpi__value">{{ pending|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--mint">
            <div class="kpi__label">Matchés</div>
            <div class="kpi__value">{{ matched|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--orange">
            <div class="kpi__label">
                <a href="{{ path('app_strawberry_unmatched') }}" class="link">Non matchés →</a>
            </div>
            <div class="kpi__value">{{ unmatched|number_format(0, '.', ' ') }}</div>
        </div>
    </div>

    {# Section A : volume monté #}
    {% if strawberry_configured %}
    <div class="card">
        <div class="card__title">Via volume monté (STRAWBERRY_DB_PATH)</div>
        <form method="post" action="{{ path('app_strawberry_sync_post') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('strawberry_sync') }}">
            <div class="row gap-16 mb-12">
                <label class="checkbox"><input type="checkbox" name="dry_run" value="1"> --dry-run</label>
                <label class="checkbox"><input type="checkbox" name="retry_unmatched" value="1"> retry unmatched</label>
            </div>
            <button type="submit" class="btn btn--primary">▷ Lancer</button>
        </form>
        <div class="muted mono fs-12 mt-12">CLI : <span class="t-3">php bin/console app:scrobbles:sync-strawberry [--retry-unmatched] [--dry-run]</span></div>
    </div>
    {% endif %}

    {# Section B : upload/download #}
    <div class="card">
        <div class="card__title">Via upload (Strawberry sur une autre machine)</div>

        {% if upload_info %}
        <div class="banner mb-20">
            <div class="kv mb-12">
                <div class="kv__row"><span class="k">Fichier</span><span class="v">strawberry.db</span></div>
                <div class="kv__row"><span class="k">Taille</span><span class="v">{{ (upload_info.size / 1024 / 1024)|number_format(1) }} Mo</span></div>
                <div class="kv__row"><span class="k">Uploadé le</span><span class="v">{{ upload_info.mtime|date('d/m/Y H:i') }}</span></div>
            </div>
            <div class="row gap-8 mb-12">
                <a href="{{ path('app_strawberry_download') }}" class="btn btn--outline btn--sm">⬇ Download</a>
                <form method="post" action="{{ path('app_strawberry_delete_upload') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('strawberry_delete_upload') }}">
                    <button type="submit" onclick="return confirm('Supprimer ?')" class="btn btn--danger btn--sm">✕ Supprimer</button>
                </form>
            </div>
            <form method="post" action="{{ path('app_strawberry_process_upload') }}" class="row gap-8">
                <input type="hidden" name="_token" value="{{ csrf_token('strawberry_process') }}">
                <button type="submit" name="retry_unmatched" value="0" class="btn btn--primary btn--sm">▷ Synchroniser</button>
                {% if unmatched > 0 %}
                <button type="submit" name="retry_unmatched" value="1" class="btn btn--outline btn--sm">↻ Retry {{ unmatched }} non matchés</button>
                {% endif %}
            </form>
        </div>
        {% endif %}

        <form method="post" action="{{ path('app_strawberry_upload') }}" enctype="multipart/form-data" class="row gap-8">
            <input type="hidden" name="_token" value="{{ csrf_token('strawberry_upload') }}">
            <input type="file" name="db_file" accept=".db" class="input">
            <button type="submit" class="btn btn--ghost">⬆ Upload strawberry.db</button>
        </form>
        <p class="muted mono fs-11 mt-8">
            Fichier SQLite Strawberry (~/.local/share/strawberry/strawberry/strawberry.db). Max 200 Mo.
        </p>
    </div>

    {# Zone dangereuse #}
    <div class="card">
        <div class="card__title t-orange">Zone dangereuse — Reset</div>
        <p class="t-3 mb-12">
            Remet <strong>tous</strong> les morceaux (matchés, doublons, non matchés, skipped)
            en <em>pending</em> pour retenter la synchronisation à zéro. Les playcounts déjà
            écrits dans Strawberry ne sont pas modifiés.
        </p>
        <form method="post" action="{{ path('app_strawberry_sync_reset') }}"
              onsubmit="return confirm('Confirmer le reset de tous les statuts Strawberry en pending ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('strawberry_sync_reset') }}">
            <button type="submit" class="btn btn--danger">⟲ Reset → pending</button>
        </form>
    </div>
{% endblock %}
