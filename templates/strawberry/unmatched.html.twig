{% extends 'base.html.twig' %}
{% block title %}Non matchés — Strawberry{% endblock %}

{% block page_subtitle %}{{ total }} groupe{{ total != 1 ? 's' : '' }}{% endblock %}

{% block header_actions %}
    <form method="post" action="{{ path('app_strawberry_rematch') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('strawberry_rematch') }}">
        <button type="submit" class="btn btn--outline btn--sm">↻ Rematcher tous</button>
    </form>
{% endblock %}

{% block body %}
    <form method="get" class="filter-bar" style="border:1px solid var(--border); border-radius:var(--r-card);">
        <div class="field">
            <label>Artiste</label>
            <input type="text" name="artist" value="{{ filter_artist }}" placeholder="Rechercher…" class="input">
        </div>
        <div class="field">
            <label>Titre</label>
            <input type="text" name="title" value="{{ filter_title }}" placeholder="Rechercher…" class="input">
        </div>
        <button type="submit" class="btn btn--primary btn--sm" style="align-self:flex-end;">Filtrer</button>
        <a href="{{ path('app_strawberry_unmatched') }}" class="btn btn--ghost btn--sm" style="align-self:flex-end;">Reset</a>
    </form>

    {% if rows is empty %}
        <div class="empty-state">Aucun non matché 🎉</div>
    {% else %}
    <div class="card" style="padding:0; overflow:hidden;">
        <table class="data-table data-table--in-card">
            <thead>
                <tr>
                    <th>Artiste</th>
                    <th>Titre</th>
                    <th>Album</th>
                    <th class="num">Scrobbles</th>
                    <th class="num">Dernier joué</th>
                </tr>
            </thead>
            <tbody>
            {% for row in rows %}
                <tr>
                    <td>{{ row.artist }}</td>
                    <td>{{ row.title }}</td>
                    <td class="mono">{{ row.album ?? '—' }}</td>
                    <td class="num">{{ row.count }}</td>
                    <td class="num mono">{{ row.last_played_at|date('d/m/Y') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% if pages > 1 %}
    <div class="pagination">
        {% if page > 1 %}<a href="{{ path('app_strawberry_unmatched', {page: page - 1, artist: filter_artist, title: filter_title}) }}">← Préc.</a>{% endif %}
        <span class="current">{{ page }}</span>
        <span>/ {{ pages }}</span>
        {% if page < pages %}<a href="{{ path('app_strawberry_unmatched', {page: page + 1, artist: filter_artist, title: filter_title}) }}">Suiv. →</a>{% endif %}
    </div>
    {% endif %}
    {% endif %}
{% endblock %}
