{# Petit bandeau qui précise d'où viennent les rows : snapshot stats
   préc-calculé, calcul en direct (filtre actif), ou fallback ambre quand
   le snapshot n'a jamais tourné. Caller passe `source`, `computed_at` et
   `compute_command`. #}
{% if source == 'snapshot' and computed_at %}
    <span class="badge badge--neutral">snapshot du {{ computed_at|date('d/m/Y H:i') }} — recalcul via <code class="mono">{{ compute_command }}</code></span>
{% elseif source == 'live_fallback' %}
    <span class="badge badge--warning">snapshot indisponible — calcul en direct ; lancer <code class="mono">{{ compute_command }}</code> pour pré-générer</span>
{% elseif source == 'live' %}
    <span class="badge badge--neutral">calcul en direct (filtre actif)</span>
{% endif %}
