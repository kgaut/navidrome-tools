{% extends 'base.html.twig' %}

{% block title %}Playlists{% endblock %}

{% macro duration(seconds) %}
    {%- set s = seconds|default(0) -%}
    {%- set h = (s / 3600)|round(0, 'floor') -%}
    {%- set m = ((s % 3600) / 60)|round(0, 'floor') -%}
    {%- if h > 0 -%}{{ h }}h{{ '%02d'|format(m) }}{%- else -%}{{ m }} min{%- endif -%}
{% endmacro %}

{% block page_subtitle %}
    {{ playlists|length }} playlist{{ playlists|length > 1 ? 's' : '' }}
    récupérée{{ playlists|length > 1 ? 's' : '' }} via l'API Subsonic, triées par dernière modification
{% endblock %}

{% block header_actions %}
    {% if definitions is not empty %}
        <form method="post" action="{{ path('app_playlists_generate') }}"
              onsubmit="return confirm('(Re)générer toutes les playlists activées ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('playlists_generate') }}">
            <button type="submit" class="btn btn--warning btn--sm">↻ Tout (re)générer</button>
        </form>
    {% endif %}
{% endblock %}

{% block body %}
    {% import _self as fmt %}

    {% if error %}
        <div class="flash flash--error">Impossible de joindre Navidrome : {{ error }}</div>
    {% endif %}

    {% if definitions is not empty %}
        <div class="card" style="padding:0;">
            <div class="row between" style="padding:14px 16px; border-bottom:1px solid var(--border);">
                <div>
                    <div class="card__title card__title--sm mb-0">Playlists générées</div>
                    <div class="muted mono fs-11 mt-8">Algorithmes de génération — création / rafraîchissement dans Navidrome.</div>
                </div>
            </div>
            <table class="data-table data-table--in-card" data-toggle-token="{{ csrf_token('playlists_toggle') }}">
                <tbody>
                    {% for d in definitions %}
                        <tr>
                            <td style="width:1px;">
                                <label class="checkbox" title="Inclure dans « Tout (re)générer »">
                                    <input type="checkbox" class="js-playlist-toggle"
                                           data-slug="{{ d.slug }}" {{ d.enabled ? 'checked' : '' }}>
                                </label>
                            </td>
                            <td>
                                <div class="cell-track__title">{{ d.name }}</div>
                                <div class="cell-track__sub">{{ d.description }}</div>
                                <div class="mono fs-11 muted mt-8">{{ d.slug }}</div>
                            </td>
                            <td class="right">
                                <form method="post" action="{{ path('app_playlists_generate_one', { slug: d.slug }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('playlists_generate_one') }}">
                                    <button type="submit" class="btn btn--warning btn--sm">↻ Régénérer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <p class="muted mono fs-11" style="padding:10px 16px; border-top:1px solid var(--border-dim);">
                La case inclut (ou non) la playlist dans « Tout (re)générer » et la planification.
                « Régénérer » fonctionne toujours, même décochée.
            </p>
        </div>
        <script>
            document.querySelectorAll('.js-playlist-toggle').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var table = cb.closest('table');
                    var token = table ? table.getAttribute('data-toggle-token') : '';
                    var body = new URLSearchParams();
                    body.set('_token', token);
                    body.set('enabled', cb.checked ? '1' : '0');
                    cb.disabled = true;
                    fetch('{{ path('app_playlists_index') }}/' + encodeURIComponent(cb.dataset.slug) + '/toggle', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: body.toString(),
                    }).then(function (r) {
                        if (!r.ok) { cb.checked = !cb.checked; }
                    }).catch(function () {
                        cb.checked = !cb.checked;
                    }).finally(function () { cb.disabled = false; });
                });
            });
        </script>
    {% endif %}

    {% if playlists is empty and not error %}
        <div class="empty-state">Aucune playlist trouvée côté Navidrome.</div>
    {% elseif playlists is not empty %}
        <div class="card" style="padding:0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Owner</th>
                        <th class="num">Morceaux</th>
                        <th class="num">Durée</th>
                        <th>Créée</th>
                        <th>Modifiée</th>
                        <th>Visibilité</th>
                    </tr>
                </thead>
                <tbody>
                    {% for p in playlists %}
                        <tr>
                            <td>
                                <a href="{{ path('app_playlists_show', { id: p.id }) }}" class="link fw-600">{{ p.name }}</a>
                                {% if p.comment %}
                                    <div class="cell-track__sub">{{ p.comment }}</div>
                                {% endif %}
                            </td>
                            <td class="t-3">{{ p.owner }}</td>
                            <td class="num">{{ p.songCount }}</td>
                            <td class="num">{{ fmt.duration(p.duration) }}</td>
                            <td class="mono">{{ p.created ? p.created|date('Y-m-d') : '—' }}</td>
                            <td class="mono">{{ p.changed ? p.changed|date('Y-m-d H:i') : '—' }}</td>
                            <td>
                                {% if p.public %}
                                    <span class="badge badge--success">Public</span>
                                {% else %}
                                    <span class="badge badge--neutral">Privé</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
