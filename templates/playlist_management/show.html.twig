{% extends 'base.html.twig' %}

{% block title %}{{ playlist.name }}{% endblock %}

{% macro duration(seconds) %}
    {%- set s = seconds|default(0) -%}
    {%- set h = (s / 3600)|round(0, 'floor') -%}
    {%- set m = ((s % 3600) / 60)|round(0, 'floor') -%}
    {%- set sec = s % 60 -%}
    {%- if h > 0 -%}{{ h }}h{{ '%02d'|format(m) }}{%- elseif m > 0 -%}{{ m }}:{{ '%02d'|format(sec) }}{%- else -%}0:{{ '%02d'|format(sec) }}{%- endif -%}
{% endmacro %}

{% block page_title %}{{ playlist.name }}{% endblock %}

{% block page_subtitle %}
    {{ playlist.songCount }} morceau{{ playlist.songCount > 1 ? 'x' : '' }} ·
    {% import _self as fmt %}durée totale {{ fmt.duration(playlist.duration) }} · owner {{ playlist.owner }}
    {% if playlist.changed %} · modifiée le {{ playlist.changed|date('Y-m-d H:i') }}{% endif %}
{% endblock %}

{% block header_actions %}
    {% if playlist.public %}
        <span class="badge badge--success">Public</span>
    {% else %}
        <span class="badge badge--neutral">Privé</span>
    {% endif %}
{% endblock %}

{% block body %}
    {% import _self as fmt %}

    <div>
        <a href="{{ path('app_playlists_index') }}" class="link mono">← Toutes les playlists</a>
    </div>

    {% if playlist.comment %}
        <p class="muted">{{ playlist.comment }}</p>
    {% endif %}

    {% if playlist.tracks is empty %}
        <div class="empty-state">Cette playlist est vide.</div>
    {% else %}
        <div class="card" style="padding:0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="num">#</th>
                        <th>Titre</th>
                        <th>Artiste</th>
                        <th>Album</th>
                        <th class="num">Année</th>
                        <th class="num">Durée</th>
                        <th class="num">Plays</th>
                        <th class="right" title="Starred">♥</th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in playlist.tracks %}
                        <tr>
                            <td class="num muted">{{ loop.index }}</td>
                            <td class="cell-track__title">{{ t.title }}</td>
                            <td class="t-3">{{ t.artist }}</td>
                            <td class="t-3">{{ t.album }}</td>
                            <td class="num">{{ t.year ?: '—' }}</td>
                            <td class="num">{{ fmt.duration(t.duration) }}</td>
                            <td class="num">{{ t.playCount }}</td>
                            <td class="right">{% if t.starred %}<span class="t-orange">♥</span>{% endif %}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
