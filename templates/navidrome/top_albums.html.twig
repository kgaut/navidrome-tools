{% extends 'base.html.twig' %}
{% block title %}Top albums — Navidrome{% endblock %}

{% block page_subtitle %}
    Top {{ top_n }} albums par lectures.
    {% include '_top_source_indicator.html.twig' with { source: source, computed_at: computed_at, compute_command: compute_command } only %}
{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_navidrome_stats') }}" class="btn btn--outline btn--sm">← Stats Navidrome</a>
    <a href="{{ path('app_lastfm_top_albums') }}" class="btn btn--outline btn--sm">Voir côté Last.fm →</a>
{% endblock %}

{% block body %}
    {% include '_top_filter_form.html.twig' with { route: 'app_navidrome_top_albums' } only %}

    {% if rows is empty %}
        <div class="empty-state">Aucune lecture pour ces filtres.</div>
    {% else %}
        {% set max_plays = rows|first.plays %}
        <div class="card" style="padding:0;">
            <table class="data-table data-table--in-card">
                <thead>
                    <tr>
                        <th class="right" style="width:48px;">#</th>
                        <th>Album</th>
                        <th class="num">Lectures</th>
                        <th class="num">Pistes</th>
                        <th>Première</th>
                        <th>Dernière</th>
                        <th class="right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for row in rows %}
                    {% set lidarr = lidarr_album_url(row.artist, row.album) %}
                    {% set navidrome = row.album_id ? navidrome_album_url(row.album_id) : null %}
                    <tr>
                        <td class="num muted">{{ loop.index }}</td>
                        <td>
                            <div class="cell-track">
                                <div>
                                    <div class="cell-track__title">{{ row.album }}</div>
                                    <div class="cell-track__sub">{{ row.artist }}</div>
                                </div>
                            </div>
                        </td>
                        <td class="num">
                            {{ row.plays|number_format(0, '.', ' ') }}
                            <div class="bar-list__track mt-8">
                                <div class="bar-list__fill{{ loop.index is odd ? '' : '--alt' }}" style="width: {{ max_plays > 0 ? (row.plays / max_plays * 100) : 0 }}%"></div>
                            </div>
                        </td>
                        <td class="num muted">{{ row.track_count }}</td>
                        <td class="mono muted nowrap">{{ row.first_played_at ? row.first_played_at|date('d/m/Y H:i') : '—' }}</td>
                        <td class="mono muted nowrap">{{ row.last_played_at ? row.last_played_at|date('d/m/Y H:i') : '—' }}</td>
                        <td class="right nowrap">
                            {% if navidrome %}
                                <a href="{{ navidrome }}" target="_blank" rel="noopener" class="link mono fs-11" title="Ouvrir dans Navidrome">▶ Navidrome</a>
                            {% endif %}
                            {% if lidarr %}
                                <a href="{{ lidarr }}" target="_blank" rel="noopener" class="link mono fs-11" title="Chercher dans Lidarr">⇗ Lidarr</a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
