{% extends 'base.html.twig' %}
{% block title %}Stats Navidrome{% endblock %}

{# Format a metric value for display: humanized hours for durations, grouped
   integer otherwise. #}
{% macro fmt(v, isDuration) %}
{%- if isDuration -%}
    {%- set h = (v // 3600) -%}
    {%- if h >= 24 -%}{{ (h // 24) }} j {{ (h % 24) }} h{%- else -%}{{ h }} h {{ ((v // 60) % 60) }} min{%- endif -%}
{%- else -%}
    {{ v|number_format(0, '.', ' ') }}
{%- endif -%}
{% endmacro %}

{# Server-rendered SVG line chart of one library metric over time.
   `rows` = list of {day, <key>}. No JS / no chart lib — a non-zero baseline
   (min..max) so slow-moving counts read as an evolution, not flat full bars. #}
{% macro evo(rows, key, label, color, isDuration) %}
{% import _self as self %}
<div class="card">
    <div class="row between mb-12">
        <div class="card__title mb-0">{{ label }}</div>
        {% if rows is not empty %}
            <div class="mono fw-600" style="color: {{ color }}">
                {{ self.fmt(attribute(rows|last, key), isDuration) }}
            </div>
        {% endif %}
    </div>
    {% if rows|length < 2 %}
        <div class="muted fs-12">L'historique se construit au fil des jours (une mesure par calcul des stats).</div>
    {% else %}
        {% set n = rows|length %}
        {% set vals = rows|map(r => attribute(r, key)) %}
        {% set min_v = min(vals) %}
        {% set max_v = max(vals) %}
        {% set span = max_v - min_v %}
        {% set pad = 10 %}
        {% set pts = '' %}
        {% for r in rows %}
            {% set v = attribute(r, key) %}
            {% set x = (loop.index0 / (n - 1) * 600)|round(2) %}
            {% set y = span > 0 ? (pad + (1 - (v - min_v) / span) * (120 - 2 * pad))|round(2) : 60 %}
            {% set pts = pts ~ x ~ ',' ~ y ~ ' ' %}
        {% endfor %}
        <svg viewBox="0 0 600 120" preserveAspectRatio="none" class="chart-area" style="height:96px;">
            <line x1="0" y1="10" x2="600" y2="10" stroke="var(--surface-3)" stroke-width="1" vector-effect="non-scaling-stroke" />
            <line x1="0" y1="60" x2="600" y2="60" stroke="var(--surface-3)" stroke-width="1" vector-effect="non-scaling-stroke" />
            <line x1="0" y1="110" x2="600" y2="110" stroke="var(--surface-3)" stroke-width="1" vector-effect="non-scaling-stroke" />
            <polyline fill="none" stroke="var(--teal)" stroke-width="2" vector-effect="non-scaling-stroke"
                      stroke-linejoin="round" stroke-linecap="round" points="{{ pts|trim }}" />
        </svg>
        <div class="axis">
            <span>{{ (rows|first).day }}</span>
            <span>min {{ self.fmt(min_v, isDuration) }} · max {{ self.fmt(max_v, isDuration) }}</span>
            <span>{{ (rows|last).day }}</span>
        </div>
    {% endif %}
</div>
{% endmacro %}

{% block page_subtitle %}
    {% if data %}calculé · {{ data.computed_at|date('d/m/Y H:i') }}{% endif %}
{% endblock %}

{% block header_actions %}
    {% if navidrome_available %}
    <form method="post" action="{{ path('app_navidrome_stats_refresh') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('navidrome_stats_refresh') }}">
        <button type="submit" class="btn btn--outline btn--sm">↻ Recalculer</button>
    </form>
    {% endif %}
{% endblock %}

{% block body %}
    {% import _self as ev %}

    {# Onglets stats #}
    <div class="tabs">
        <a href="{{ path('app_stats') }}" class="tab">Global</a>
        <a href="{{ path('app_lastfm_stats') }}" class="tab">Last.fm</a>
        <a href="{{ path('app_navidrome_stats') }}" class="tab tab--active">Navidrome</a>
    </div>

    {% if not navidrome_available and not data %}
        <div class="banner banner--warning">
            <strong>Base Navidrome indisponible.</strong>
            Vérifiez <code>NAVIDROME_DB_PATH</code> et <code>NAVIDROME_USER</code>.
        </div>
    {% elseif not data %}
        <div class="banner banner--warning">
            <strong>Aucune statistique en cache.</strong>
            Cliquez sur <em>↻ Recalculer</em> pour générer un premier instantané
            (l'agrégation peut prendre quelques secondes sur de grosses bibliothèques),
            ou planifiez la commande <code>app:navidrome:stats:compute</code> dans un crontab.
        </div>
    {% else %}

    {% if not navidrome_available %}
        <div class="banner banner--warning">
            Base Navidrome actuellement indisponible — données issues du dernier snapshot.
        </div>
    {% endif %}

    {# KPIs bibliothèque + écoutes #}
    <div class="grid grid--6">
        <div class="kpi">
            <div class="kpi__label">Morceaux</div>
            <div class="kpi__value kpi__value--sm">{{ data.library.tracks|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--teal">
            <div class="kpi__label">Artistes</div>
            <div class="kpi__value kpi__value--sm">{{ data.library.artists|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi">
            <div class="kpi__label">Albums</div>
            <div class="kpi__value kpi__value--sm">{{ data.library.albums|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--mint">
            <div class="kpi__label">Bibliothèque</div>
            {% set total_h = (data.library.duration_seconds // 3600) %}
            {% set total_m = ((data.library.duration_seconds // 60) % 60) %}
            <div class="kpi__value kpi__value--sm" style="font-size:18px;">
                {% if total_h >= 24 %}
                    {{ (total_h // 24) }} j {{ (total_h % 24) }} h
                {% else %}
                    {{ total_h }} h {{ total_m }} min
                {% endif %}
            </div>
            <div class="kpi__delta muted">{{ data.library.duration_seconds|number_format(0, '.', ' ') }} s</div>
        </div>
        <div class="kpi">
            <div class="kpi__label">Lectures totales</div>
            <div class="kpi__value kpi__value--sm">{{ data.total_plays|number_format(0, '.', ' ') }}</div>
            {% if not data.has_scrobbles %}
                <div class="kpi__delta t-orange">via annotation (Navidrome &lt; 0.55)</div>
            {% endif %}
        </div>
        <div class="kpi kpi--teal">
            <div class="kpi__label">Morceaux joués</div>
            <div class="kpi__value kpi__value--sm">{{ data.distinct_played|number_format(0, '.', ' ') }}</div>
            {% if data.library.tracks > 0 %}
                <div class="kpi__delta muted">{{ (data.distinct_played / data.library.tracks * 100)|round(1) }} % de la lib</div>
            {% endif %}
        </div>
    </div>

    {# ♥ coups de cœur #}
    <div class="grid grid--3">
        <div class="kpi kpi--orange">
            <div class="kpi__label">♥ Morceaux</div>
            <div class="kpi__value kpi__value--sm">{{ data.starred.tracks|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--orange">
            <div class="kpi__label">♥ Albums</div>
            <div class="kpi__value kpi__value--sm">{{ data.starred.albums|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--orange">
            <div class="kpi__label">♥ Artistes</div>
            <div class="kpi__value kpi__value--sm">{{ data.starred.artists|number_format(0, '.', ' ') }}</div>
        </div>
    </div>

    {# Évolution de la bibliothèque (une mesure par jour, à chaque calcul) #}
    {% set history = data.library_history ?? [] %}
    <div class="grid grid--2">
        {{ ev.evo(history, 'tracks', 'Évolution — morceaux', '#0ea5e9', false) }}
        {{ ev.evo(history, 'artists', 'Évolution — artistes', '#22c55e', false) }}
        {{ ev.evo(history, 'albums', 'Évolution — albums', '#a855f7', false) }}
        {{ ev.evo(history, 'duration_seconds', 'Évolution — durée totale', '#f59e0b', true) }}
    </div>

    {# Streaks #}
    {% if data.streaks is defined %}
    <div class="grid grid--3">
        <div class="kpi kpi--orange">
            <div class="kpi__label">🔥 Streak actuelle</div>
            <div class="kpi__value kpi__value--sm">{{ data.streaks.current|number_format(0, '.', ' ') }}<span class="unit"> j</span></div>
            {% if data.streaks.current > 0 and data.streaks.current_started_at %}
                <div class="kpi__delta muted">depuis le {{ data.streaks.current_started_at|date('d/m/Y') }}</div>
            {% endif %}
        </div>
        <div class="kpi">
            <div class="kpi__label">Plus longue (12 mois)</div>
            <div class="kpi__value kpi__value--sm">{{ data.streaks.longest_period|number_format(0, '.', ' ') }}<span class="unit"> j</span></div>
            {% if data.streaks.longest_period > 0 and data.streaks.longest_period_started_at %}
                <div class="kpi__delta muted">du {{ data.streaks.longest_period_started_at|date('d/m/Y') }} au {{ data.streaks.longest_period_ended_at|date('d/m/Y') }}</div>
            {% endif %}
        </div>
        <div class="kpi">
            <div class="kpi__label">Plus longue (all-time)</div>
            <div class="kpi__value kpi__value--sm">{{ data.streaks.longest_alltime|number_format(0, '.', ' ') }}<span class="unit"> j</span></div>
            {% if data.streaks.longest_alltime > 0 and data.streaks.longest_alltime_started_at %}
                <div class="kpi__delta muted">du {{ data.streaks.longest_alltime_started_at|date('d/m/Y') }} au {{ data.streaks.longest_alltime_ended_at|date('d/m/Y') }}</div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# Disparité Last.fm ↔ Navidrome — mois et années où la bibliothèque
       couvre le moins bien les scrobbles Last.fm. #}
    {% if data.disparity is defined %}
    <div class="col">
        <div class="row between wrap">
            <div class="card__title mb-0">Disparité Last.fm ↔ Navidrome</div>
            {% if data.disparity.anchor_month %}
                <p class="muted mono fs-11 mb-0">
                    Comparaison depuis {{ data.disparity.anchor_month }} (premier scrobble Navidrome). Triés par écart de plays décroissant.
                </p>
            {% endif %}
        </div>
        {% if data.disparity.anchor_month is null %}
            <div class="empty-state">
                Aucune écoute Navidrome encore — la disparité apparaîtra après le premier sync.
            </div>
        {% elseif data.disparity.by_month is empty and data.disparity.by_year is empty %}
            <div class="empty-state">
                Aucune disparité significative depuis {{ data.disparity.anchor_month }} 🎉
            </div>
        {% else %}
            <div class="grid grid--2">
                {% for panel in [
                    { title: 'Top mois', rows: data.disparity.by_month, label_key: 'month' },
                    { title: 'Top années', rows: data.disparity.by_year, label_key: 'year' },
                ] %}
                    <div class="card" style="padding:0;">
                        <div class="card__title" style="padding:16px 16px 0;">{{ panel.title }}</div>
                        {% if panel.rows is empty %}
                            <div class="empty-state" style="border:none;">—</div>
                        {% else %}
                            <table class="data-table data-table--in-card" style="margin-top:8px;">
                                <thead>
                                    <tr>
                                        <th>Période</th>
                                        <th class="num">Last.fm</th>
                                        <th class="num">Navidrome</th>
                                        <th class="num">Écart</th>
                                        <th class="num">Couverture</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for row in panel.rows %}
                                    {% set tone = row.coverage_pct >= 80 ? 'success' : (row.coverage_pct >= 40 ? 'warning' : 'warning') %}
                                    <tr>
                                        <td class="fw-600">{{ attribute(row, panel.label_key) }}</td>
                                        <td class="num">{{ row.lastfm|number_format(0, '.', ' ') }}</td>
                                        <td class="num">{{ row.navidrome|number_format(0, '.', ' ') }}</td>
                                        <td class="num fw-600 {{ row.coverage_pct < 40 ? 't-orange' : '' }}">{{ row.gap|number_format(0, '.', ' ') }}</td>
                                        <td class="num">
                                            <span class="badge badge--{{ tone }}">{{ row.coverage_pct }}%</span>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
    {% endif %}

    {# Lectures par mois / semaine / jour #}
    {% set unit = 'lectures' %}
    {% set charts = [
        { title: 'Lectures — 12 derniers mois', rows: data.plays_by_month, key: 'month' },
        { title: 'Lectures — 15 dernières semaines', rows: data.plays_by_week ?? [], key: 'week' },
        { title: 'Lectures — 15 derniers jours', rows: data.plays_by_day ?? [], key: 'day' },
    ] %}
    {% for chart in charts %}
    {% if chart.rows is not empty %}
    <div class="card">
        <div class="card__title">{{ chart.title }}</div>
        {% set max_v = max(chart.rows|map(r => r.plays)) %}
        <div class="bars">
            {% for row in chart.rows %}
            <div class="bars__col">
                <div class="bars__bar"
                     style="height: {{ max_v > 0 ? ((row.plays / max_v * 100)|round) : 0 }}%"
                     title="{{ attribute(row, chart.key) }} : {{ row.plays }} {{ unit }}"></div>
                <div class="bars__label">
                    {%- if chart.key == 'month' -%}
                        {{ row.month|slice(5, 2) }}/{{ row.month|slice(2, 2) }}
                    {%- else -%}
                        {{ attribute(row, chart.key)|slice(8, 2) }}/{{ attribute(row, chart.key)|slice(5, 2) }}
                    {%- endif -%}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}
    {% endfor %}

    {# Top all-time #}
    <div class="grid grid--3">
        {% if data.top_artists is not empty %}
        <div class="card">
            <div class="card__title">Top artistes (all-time)</div>
            <div class="bar-list">
                {% set max_a = data.top_artists[0].plays %}
                {% for i, row in data.top_artists %}
                <div class="bar-list__row">
                    <div><span><span class="muted mono">{{ i + 1 }}</span> {{ row.artist }}</span><span class="count">{{ row.plays }}</span></div>
                    <div class="bar-list__track"><div class="bar-list__fill" style="width: {{ (row.plays / max_a * 100)|round }}%"></div></div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {% if data.top_tracks is not empty %}
        <div class="card">
            <div class="card__title">Top morceaux (all-time)</div>
            <div class="bar-list">
                {% set max_t = data.top_tracks[0].plays %}
                {% for i, row in data.top_tracks %}
                <div class="bar-list__row">
                    <div><span><span class="muted mono">{{ i + 1 }}</span> {{ row.title }} <span class="muted">· {{ row.artist }}</span></span><span class="count">{{ row.plays }}</span></div>
                    <div class="bar-list__track"><div class="bar-list__fill bar-list__fill--alt" style="width: {{ (row.plays / max_t * 100)|round }}%"></div></div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {% if data.top_albums is not empty %}
        <div class="card">
            <div class="card__title">Top albums (all-time)</div>
            <div class="bar-list">
                {% set max_al = data.top_albums[0].plays %}
                {% for i, row in data.top_albums %}
                <div class="bar-list__row">
                    <div><span><span class="muted mono">{{ i + 1 }}</span> {{ row.album }} <span class="muted">· {{ row.album_artist }}</span></span><span class="count">{{ row.plays }}</span></div>
                    <div class="bar-list__track"><div class="bar-list__fill" style="width: {{ (row.plays / max_al * 100)|round }}%; background: var(--orange);"></div></div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    {# 100 derniers lus + 25 derniers ♥ #}
    <div class="grid grid--2">
        {% if data.recent_scrobbles is not empty %}
        <div class="card" style="padding:0;">
            <div class="card__title" style="padding:16px 16px 0;">100 derniers morceaux lus</div>
            <div style="max-height:640px; overflow-y:auto; margin-top:8px;">
                <table class="data-table data-table--in-card">
                    <tbody>
                    {% for row in data.recent_scrobbles %}
                    <tr>
                        <td class="mono nowrap" style="width:120px;">{{ row.played_at|date('d/m H:i') }}</td>
                        <td>
                            <div class="cell-track__title">{{ row.title ?: '—' }}</div>
                            <div class="cell-track__sub">{{ row.artist ?: '—' }}{% if row.album %} · {{ row.album }}{% endif %}</div>
                        </td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% else %}
        <div class="empty-state">
            Aucune écoute trouvée dans Navidrome.
            {% if not data.has_scrobbles %}
                <br><span class="fs-12 muted">La table <code>scrobbles</code> n'existe pas (Navidrome &lt; 0.55) ; les écoutes récentes n'apparaîtront qu'après mise à jour.</span>
            {% endif %}
        </div>
        {% endif %}

        {% if data.recent_starred is not empty %}
        <div class="card" style="padding:0;">
            <div class="card__title" style="padding:16px 16px 0;">25 derniers coups de cœur</div>
            <div style="max-height:640px; overflow-y:auto; margin-top:8px;">
                <table class="data-table data-table--in-card">
                    <tbody>
                    {% for row in data.recent_starred %}
                    <tr>
                        <td class="t-orange" style="width:40px; text-align:center;">♥</td>
                        <td>
                            <div class="cell-track__title">{{ row.title ?: '—' }}</div>
                            <div class="cell-track__sub">{{ row.artist ?: '—' }}{% if row.album %} · {{ row.album }}{% endif %}</div>
                        </td>
                        <td class="mono num nowrap" style="width:96px;">{{ row.starred_at|date('d/m/Y') }}</td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% else %}
        <div class="empty-state">Aucun coup de cœur enregistré dans Navidrome.</div>
        {% endif %}
    </div>

    {% endif %}
{% endblock %}
