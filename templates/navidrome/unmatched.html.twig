{% extends 'base.html.twig' %}
{% block title %}Non matchés — Navidrome{% endblock %}

{% block page_subtitle %}{{ total }} groupe{{ total != 1 ? 's' : '' }} (artiste, titre, album){% endblock %}

{% block header_actions %}
    <form method="post" action="{{ path('app_navidrome_suggest_aliases') }}"
          onsubmit="return confirm('Interroger MusicBrainz pour les artistes ayant ≥3 scrobbles non matchés ? Throttle ~1 req/s, les alias uniques sont appliqués automatiquement.');">
        <input type="hidden" name="_token" value="{{ csrf_token('navidrome_suggest_aliases') }}">
        <button type="submit" class="btn btn--primary btn--sm"
                title="Interroge MusicBrainz et crée les alias artiste uniques haute-confiance (≥3 scrobbles)">
            ⌖ Suggérer des alias
        </button>
    </form>
    <form method="post" action="{{ path('app_navidrome_rematch') }}" class="row gap-8">
        <input type="hidden" name="_token" value="{{ csrf_token('navidrome_rematch') }}">
        <label class="checkbox"><input type="checkbox" name="auto_stop" value="1"> auto-stop</label>
        <button type="submit" class="btn btn--outline btn--sm">↻ Rematcher tous</button>
    </form>
{% endblock %}

{% block body %}
    <form method="get" class="filter-bar" style="border:1px solid var(--border); border-radius:var(--r-card);">
        <div class="field">
            <label>Artiste</label>
            <input type="text" name="artist" value="{{ filter_artist }}" placeholder="Rechercher…" class="input">
        </div>
        <div class="field">
            <label>Titre</label>
            <input type="text" name="title" value="{{ filter_title }}" placeholder="Rechercher…" class="input">
        </div>
        <button type="submit" class="btn btn--primary btn--sm" style="align-self:flex-end;">Filtrer</button>
        <a href="{{ path('app_navidrome_unmatched') }}" class="btn btn--ghost btn--sm" style="align-self:flex-end;">Reset</a>
        <a href="{{ path('app_lastfm_alias_index') }}" class="link mono fs-12 ml-auto">Gérer les alias track →</a>
        <a href="{{ path('app_lastfm_artist_alias_index') }}" class="link mono fs-12">Alias artiste →</a>
    </form>

    {% if rows is empty %}
        <div class="empty-state">Aucun scrobble non matché 🎉</div>
    {% else %}
    <div class="card" style="padding:0; overflow:hidden;">
        <table class="data-table data-table--in-card">
            <thead>
                <tr>
                    <th>Artiste</th>
                    <th>Titre</th>
                    <th>Album</th>
                    <th>Raison</th>
                    <th class="num">Scrobbles</th>
                    <th class="num">Dernier joué</th>
                    <th class="right">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for row in rows %}
                {% set lidarr = row.album ? lidarr_album_url(row.artist, row.album) : lidarr_artist_url(row.artist) %}
                <tr>
                    <td>{{ row.artist }}</td>
                    <td>{{ row.title }}</td>
                    <td class="mono">{{ row.album ?? '—' }}</td>
                    <td>
                        {% set d = row.diagnosis %}
                        {% if d.reason == 'artist_unknown' %}
                            <span class="badge badge--warning" title="Aucun artiste comparable dans la bibliothèque Navidrome.">Artiste inconnu</span>
                        {% elseif d.reason == 'matcher_gap' %}
                            <span class="badge badge--accent"
                                  title="Track présente en bibliothèque mais la cascade matcher l'a ratée. Un rematch (cache négatif purgé) devrait la résoudre.">
                                Présente — cascade KO
                            </span>
                        {% elseif d.reason == 'artist_near_match' %}
                            <span class="badge badge--warning"
                                  title="Suggestions : {{ d.artist_suggestions|map(s => s.name ~ ' (' ~ s.distance ~ ')')|join(', ') }}">
                                Artiste ≈ {{ d.artist_suggestions[0].name }}
                            </span>
                        {% elseif d.reason == 'title_near_match' %}
                            <span class="badge badge--accent"
                                  title="Suggestions : {{ d.title_suggestions|map(s => s.title ~ ' (' ~ s.distance ~ ')')|join(', ') }}">
                                Titre ≈ {{ d.title_suggestions[0].title }}
                            </span>
                        {% elseif d.reason == 'track_missing' %}
                            <span class="badge badge--neutral" title="L'artiste existe mais ce titre est introuvable dans la bibliothèque.">Track absente</span>
                        {% else %}
                            <span class="badge badge--neutral">—</span>
                        {% endif %}
                    </td>
                    <td class="num">{{ row.count }}</td>
                    <td class="num mono">{{ row.last_played_at|date('d/m/Y') }}</td>
                    <td class="right nowrap">
                        {% if lidarr %}
                            <a href="{{ lidarr }}" target="_blank" rel="noopener" class="mono fs-11 muted" title="Chercher dans Lidarr">⇗ Lidarr</a>
                        {% endif %}
                        <a href="{{ path('app_lastfm_alias_new', {artist: row.artist, title: row.title}) }}" class="mono fs-11 t-teal">✎ Alias</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% if pages > 1 %}
    <div class="pagination">
        {% if page > 1 %}<a href="{{ path('app_navidrome_unmatched', {page: page - 1, artist: filter_artist, title: filter_title}) }}">← Préc.</a>{% endif %}
        <span class="current">{{ page }}</span>
        <span>/ {{ pages }}</span>
        {% if page < pages %}<a href="{{ path('app_navidrome_unmatched', {page: page + 1, artist: filter_artist, title: filter_title}) }}">Suiv. →</a>{% endif %}
    </div>
    {% endif %}
    {% endif %}
{% endblock %}
