{% extends 'base.html.twig' %}
{% block title %}Sync Navidrome{% endblock %}

{% block page_subtitle %}matching · insertion · contrôle conteneur{% endblock %}

{% block body %}
    <div class="banner banner--warning">
        <strong>Navidrome doit être arrêté</strong> pour éviter toute corruption SQLite.
        Utilisez <span class="mono">--auto-stop</span> en CLI ou cochez la case ci-dessous
        (requiert <span class="mono">NAVIDROME_CONTAINER_NAME</span> configuré).
    </div>

    {# 3 cartes : conteneur · en attente · non-matchés #}
    <div class="grid grid--3">
        <div class="card">
            <div class="card__title card__title--sm">Conteneur Navidrome</div>
            <div class="status-pill mb-12">
                <span class="dot{{ (container_status ?? null) == 'running' ? '' : ' dot--warning' }}"></span>
                {{ (container_status ?? null) == 'running' ? 'en ligne' : 'arrêté' }}
            </div>
            <div class="row gap-8">
                <form method="post" action="{{ path('app_navidrome_container_start') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('navidrome_container') }}">
                    <button type="submit" class="btn btn--success btn--sm">▷ démarrer</button>
                </form>
                <form method="post" action="{{ path('app_navidrome_container_stop') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('navidrome_container') }}">
                    <button type="submit" class="btn btn--warning btn--sm">■ arrêter</button>
                </form>
            </div>
        </div>

        <div class="kpi kpi--teal">
            <div class="kpi__label">En attente de sync</div>
            <div class="kpi__value">{{ pending|number_format(0, '.', ' ') }}</div>
        </div>

        <div class="kpi kpi--orange">
            <div class="kpi__label">
                <a href="{{ path('app_navidrome_unmatched') }}" class="link">Non-matchés →</a>
            </div>
            <div class="kpi__value">{{ unmatched|number_format(0, '.', ' ') }}</div>
            <div class="kpi__delta muted">{{ matched|number_format(0, '.', ' ') }} matchés · {{ duplicates|number_format(0, '.', ' ') }} doublons</div>
        </div>
    </div>

    {# Formulaire sync #}
    <div class="card">
        <div class="card__title">Lancer la synchronisation</div>
        <form method="post" action="{{ path('app_navidrome_sync_post') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('navidrome_sync') }}">

            <div class="row gap-16 mb-12">
                <label class="checkbox">
                    <input type="checkbox" name="auto_stop" value="1"> --auto-stop (requiert NAVIDROME_CONTAINER_NAME)
                </label>
                <label class="checkbox">
                    <input type="checkbox" name="dry_run" value="1"> --dry-run (matching sans écriture)
                </label>
            </div>

            <div class="row gap-16 mb-12">
                <div class="field">
                    <label>Limite (0 = tout)</label>
                    <input type="number" name="limit" value="0" min="0" class="input">
                </div>
                <div class="field">
                    <label>Tolérance dedup (s)</label>
                    <input type="number" name="tolerance" value="60" min="0" class="input">
                </div>
            </div>

            <button type="submit" class="btn btn--primary">▷ sync-navidrome</button>
        </form>
        <form method="post" action="{{ path('app_navidrome_rematch') }}" class="row gap-8 mt-12">
            <input type="hidden" name="_token" value="{{ csrf_token('navidrome_rematch') }}">
            <label class="checkbox">
                <input type="checkbox" name="auto_stop" value="1"> --auto-stop
            </label>
            <button type="submit" class="btn btn--outline">↻ rematch</button>
        </form>

        <div class="muted mono fs-12 mt-12">
            CLI : <span class="t-3">php bin/console app:scrobbles:sync-navidrome [--auto-stop] [--dry-run] [--limit=N]</span>
        </div>
    </div>

    {# Zone dangereuse #}
    <div class="card">
        <div class="card__title t-orange">Zone dangereuse — Reset</div>
        <p class="t-3 mb-12">
            Remet <strong>tous</strong> les morceaux (matchés, doublons, non matchés, skipped)
            en <em>pending</em> pour retenter la synchronisation à zéro. Les playcounts déjà
            écrits dans Navidrome ne sont pas modifiés.
        </p>
        <form method="post" action="{{ path('app_navidrome_sync_reset') }}"
              onsubmit="return confirm('Confirmer le reset de tous les statuts Navidrome en pending ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('navidrome_sync_reset') }}">
            <button type="submit" class="btn btn--danger">⟲ Reset → pending</button>
        </form>
    </div>
{% endblock %}
