{% extends 'base.html.twig' %}

{% block title %}Heatmap d'écoute{% endblock %}

{% block body %}
    <div class="flex items-start justify-between mb-4 flex-wrap gap-3">
        <h1 class="text-2xl font-semibold">Heatmap d'écoute</h1>
        <a href="{{ path('app_stats') }}" class="text-sm text-slate-500 hover:underline">← Vue d'ensemble</a>
    </div>

    {% if not has_scrobbles %}
        <div class="bg-amber-50 border border-amber-300 text-amber-800 rounded p-4 mb-6 text-sm">
            La table <code>scrobbles</code> de Navidrome est introuvable. Les heatmaps nécessitent Navidrome ≥ 0.55.
        </div>
    {% endif %}

    {# ---------- Day × hour heatmap (last 90 days) ---------- #}
    <div class="bg-white shadow rounded p-5 mb-6 overflow-x-auto">
        <h2 class="font-semibold text-sm mb-3">
            Jour × heure — 90 derniers jours
            <span class="text-xs text-slate-500">(max : {{ max_hour|number_format(0, '.', ' ') }} écoutes)</span>
        </h2>
        <table class="text-xs border-collapse">
            <thead>
                <tr>
                    <th class="w-10"></th>
                    {% for h in 0..23 %}
                        <th class="w-7 px-1 py-1 text-center text-slate-500 font-normal">{{ '%02d'|format(h) }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {# Re-order to start from Monday for FR locale convention #}
                {% set day_order = [1, 2, 3, 4, 5, 6, 0] %}
                {% for dow in day_order %}
                    <tr>
                        <td class="pr-2 py-1 text-right text-slate-500">{{ day_labels[dow] }}</td>
                        {% for h in 0..23 %}
                            {% set value = matrix[dow][h] ?? 0 %}
                            {% set ratio = max_hour > 0 ? value / max_hour : 0 %}
                            {% set opacity = ratio > 0 ? (0.15 + ratio * 0.85) : 0 %}
                            <td class="w-7 h-7 border border-white"
                                style="background-color: rgba(16, 185, 129, {{ opacity }});"
                                title="{{ day_labels[dow] }} {{ '%02d'|format(h) }}h : {{ value }} écoutes">
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ---------- Year × day heatmap (GitHub-style) ---------- #}
    <div class="bg-white shadow rounded p-5">
        <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
            <h2 class="font-semibold text-sm">
                Année {{ year }} — jour par jour
                <span class="text-xs text-slate-500">(max : {{ max_daily|number_format(0, '.', ' ') }} écoutes)</span>
            </h2>
            <form method="get" class="flex items-center gap-2 text-sm">
                <label for="year">Année :</label>
                <select name="year" id="year" onchange="this.form.submit()" class="border rounded px-2 py-1">
                    {% for y in available_years %}
                        <option value="{{ y }}" {{ y == year ? 'selected' : '' }}>{{ y }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>

        <div class="overflow-x-auto">
            <div class="flex" style="gap: 3px;">
                {# day labels column #}
                <div class="flex flex-col text-xs text-slate-400 mr-1" style="gap: 3px; padding-top: 1.1rem;">
                    {% for dow in 0..6 %}
                        <div class="h-3 leading-none">{{ dow == 1 or dow == 3 or dow == 5 ? day_labels[dow] : '' }}</div>
                    {% endfor %}
                </div>
                {# weeks columns #}
                <div class="flex" style="gap: 3px;">
                    {% set last_month = '' %}
                    {% for week in weeks %}
                        <div class="flex flex-col" style="gap: 3px;">
                            {% set first_real = null %}
                            {% for cell in week.cells %}
                                {% if cell and first_real is null %}
                                    {% set first_real = cell %}
                                {% endif %}
                            {% endfor %}
                            <div class="h-3 text-xs text-slate-400 leading-none">
                                {% if first_real %}
                                    {% set month_index = first_real.date|slice(5, 2)|number_format(0) %}
                                    {% if first_real.date|slice(8, 2) <= '07' and last_month != month_index %}
                                        {{ month_labels[month_index] }}
                                        {% set last_month = month_index %}
                                    {% endif %}
                                {% endif %}
                            </div>
                            {% for cell in week.cells %}
                                {% if cell %}
                                    {% set ratio = max_daily > 0 ? cell.plays / max_daily : 0 %}
                                    {% set opacity = ratio > 0 ? (0.15 + ratio * 0.85) : 0 %}
                                    <div class="w-3 h-3 rounded-sm"
                                         style="background-color: {{ cell.plays > 0 ? 'rgba(16, 185, 129, ' ~ opacity ~ ')' : '#e5e7eb' }};"
                                         title="{{ cell.date }} : {{ cell.plays }} écoutes"></div>
                                {% else %}
                                    <div class="w-3 h-3"></div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        <p class="text-xs text-slate-500 mt-3">Plus la cellule est saturée, plus tu as écouté ce jour-là.</p>
    </div>
{% endblock %}
