{% extends 'base.html.twig' %}
{% block title %}Statistiques{% endblock %}

{% block page_subtitle %}
    {% if data.computed_at is defined %}calculé · {{ data.computed_at|date('d/m H:i') }}{% endif %}
{% endblock %}

{% block header_actions %}
    <form method="post" action="{{ path('app_stats_refresh') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('stats_refresh') }}">
        <input type="hidden" name="period" value="{{ period }}">
        <button type="submit" class="btn btn--outline btn--sm">↻ Recalculer</button>
    </form>
{% endblock %}

{% block body %}
    {# Onglets stats #}
    <div class="tabs">
        <a href="{{ path('app_stats') }}" class="tab tab--active">Global</a>
        <a href="{{ path('app_lastfm_stats') }}" class="tab">Last.fm</a>
        <a href="{{ path('app_navidrome_stats') }}" class="tab">Navidrome</a>
    </div>

    {# Sélecteur de période #}
    <div class="row wrap">
        {% for key, label in periods %}
        <a href="{{ path('app_stats', {period: key}) }}"
           class="btn btn--sm {{ key == period ? 'btn--primary' : 'btn--outline' }}">
            {{ label }}
        </a>
        {% endfor %}
    </div>

    {# KPIs #}
    <div class="grid grid--6">
        <div class="kpi">
            <div class="kpi__label">Lectures (période)</div>
            <div class="kpi__value kpi__value--sm">{{ data.total_plays|number_format(0, '.', ' ') }}</div>
        </div>
        <div class="kpi kpi--teal">
            <div class="kpi__label">Total historique</div>
            <div class="kpi__value kpi__value--sm">{{ total_scrobbles|number_format(0, '.', ' ') }}</div>
        </div>
        {% if data.top_artists is not empty %}
        <div class="kpi kpi--mint">
            <div class="kpi__label">Artiste #1</div>
            <div class="kpi__value kpi__value--sm nowrap" style="overflow:hidden; text-overflow:ellipsis; font-size:18px;">{{ data.top_artists[0].artist }}</div>
            <div class="kpi__delta muted">{{ data.top_artists[0].plays }} lectures</div>
        </div>
        {% endif %}
    </div>

    {# Heatmap d'activité — fenêtre fixe sur les 365 derniers jours, indépendante du sélecteur de période. #}
    {% if heatmap.total > 0 %}
    <div class="card">
        <div class="row between mb-12 wrap">
            <div>
                <div class="card__title mb-6">Activité — 12 derniers mois</div>
                <div class="muted mono fs-11">
                    {{ heatmap.total|number_format(0, '.', ' ') }} lectures du
                    {{ heatmap.start|date('d/m/Y') }} au {{ heatmap.end|date('d/m/Y') }} —
                    pic à {{ heatmap.max|number_format(0, '.', ' ') }}/jour
                </div>
            </div>
            <div class="heat-legend">
                <span>Moins</span>
                {% for lvl in 0..4 %}
                <span class="heat-cell heat-cell--lvl{{ lvl }}"></span>
                {% endfor %}
                <span>Plus</span>
            </div>
        </div>

        <div class="heatmap">
            {% for week in heatmap.weeks %}
                <div class="heatmap__week">
                    {% for cell in week %}
                        {% if cell is null %}
                            <span class="heat-cell" style="background:transparent;"></span>
                        {% else %}
                            <span class="heat-cell heat-cell--lvl{{ cell.level }}"
                                  title="{{ cell.date|date('d/m/Y') }} — {{ cell.plays }} lecture{{ cell.plays > 1 ? 's' : '' }}"></span>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <div class="grid grid--2">
        {# Top artistes #}
        {% if data.top_artists is not empty %}
        <div class="card">
            <div class="card__title">Top artistes</div>
            <div class="bar-list">
                {% set max_plays = data.top_artists[0].plays %}
                {% for i, row in data.top_artists %}
                <div class="bar-list__row">
                    <div><span><span class="muted mono">{{ i + 1 }}</span> {{ row.artist }}</span><span class="count">{{ row.plays }}</span></div>
                    <div class="bar-list__track"><div class="bar-list__fill" style="width: {{ (row.plays / max_plays * 100)|round }}%"></div></div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Top morceaux #}
        {% if data.top_tracks is not empty %}
        <div class="card">
            <div class="card__title">Top morceaux</div>
            <div class="bar-list">
                {% set max_plays_t = data.top_tracks[0].plays %}
                {% for i, row in data.top_tracks|slice(0, 25) %}
                <div class="bar-list__row">
                    <div><span><span class="muted mono">{{ i + 1 }}</span> {{ row.title }} <span class="muted">· {{ row.artist }}</span></span><span class="count">{{ row.plays }}</span></div>
                    <div class="bar-list__track"><div class="bar-list__fill bar-list__fill--alt" style="width: {{ (row.plays / max_plays_t * 100)|round }}%"></div></div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    {# Lectures par mois #}
    {% if data.plays_by_month is not empty %}
    <div class="card">
        <div class="card__title">Lectures par mois</div>
        {% set max_month = max(data.plays_by_month|map(r => r.plays)) %}
        <div class="bars">
            {% for row in data.plays_by_month %}
            <div class="bars__col">
                <div class="bars__bar"
                     style="height: {{ max_month > 0 ? ((row.plays / max_month * 100)|round) : 0 }}%"
                     title="{{ row.month }} : {{ row.plays }} lectures"></div>
                <div class="bars__label">{{ row.month|slice(5, 2) }}/{{ row.month|slice(2, 2) }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# Lectures par jour de la semaine #}
    {% if data.plays_by_dow is not empty %}
    <div class="card">
        <div class="card__title">Lectures par jour de la semaine</div>
        {% set days = ['Dim', 'Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'] %}
        {% set dow_map = {} %}
        {% for row in data.plays_by_dow %}{% set dow_map = dow_map|merge({(row.dow): row.plays}) %}{% endfor %}
        {% set max_dow = max(data.plays_by_dow|map(r => r.plays)) %}
        <div class="bars">
            {% for d in 0..6 %}
            {% set plays = dow_map[d] is defined ? dow_map[d] : 0 %}
            <div class="bars__col">
                <div class="bars__bar bars__bar--grad"
                     style="height: {{ max_dow > 0 ? ((plays / max_dow * 100)|round) : 0 }}%"
                     title="{{ days[d] }} : {{ plays }} lectures"></div>
                <div class="bars__label">{{ days[d] }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}
{% endblock %}
