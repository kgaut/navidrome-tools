###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMeInProduction0123456789abcdef
APP_TIMEZONE=UTC
APP_VERSION=dev
###< symfony/framework-bundle ###

###> Auth ###
APP_AUTH_USER=admin
APP_AUTH_PASSWORD=changeme
###< Auth ###

###> Database ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< Database ###

###> Symfony Messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< Symfony Messenger ###

###> Navidrome ###
NAVIDROME_DB_PATH=%kernel.project_dir%/var/navidrome.db
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=admin
NAVIDROME_PASSWORD=changeme
NAVIDROME_CONTAINER_NAME=
NAVIDROME_STOP_TIMEOUT_SECONDS=60
NAVIDROME_STOP_WAIT_CEILING_SECONDS=30
###< Navidrome ###

###> Last.fm ###
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USER=
LASTFM_PAGE_DELAY_SECONDS=10
LASTFM_FUZZY_MAX_DISTANCE=0
LASTFM_MATCH_CACHE_TTL_DAYS=30
###< Last.fm ###

###> Strawberry ###
STRAWBERRY_DB_PATH=
###< Strawberry ###

###> Backup ###
BACKUP_RETENTION_DAYS=7
###< Backup ###

###> Run history ###
RUN_HISTORY_RETENTION_DAYS=90
###< Run history ###

###> Notifications ###
NOTIFY_DRIVERS=
NOTIFY_ON=error
NOTIFY_GOTIFY_URL=
NOTIFY_GOTIFY_TOKEN=
NOTIFY_GOTIFY_PRIORITY=5
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_DISCORD_WEBHOOK_URL=
NOTIFY_PUSHOVER_TOKEN=
NOTIFY_PUSHOVER_USER=
###< Notifications ###
