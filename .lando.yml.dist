name: navidrome-tools

# Recommended Lando stack for Symfony 7 :
#  - PHP 8.3 served via nginx
#  - Composer 2 (required by Symfony Flex)
#  - SQLite for both the tool's DB and the (read-only mounted) Navidrome DB,
#    so no extra database service is needed.

services:
  appserver:
    type: php:8.3
    via: nginx
    webroot: public
    composer_version: '2'
    xdebug: false
    config:
      vhosts: .lando/nginx.conf
    build:
      - composer install
    overrides:
      environment: &app_env
        APP_ENV: dev
        APP_DEBUG: '1'
        APP_SECRET: dev-secret-change-me-please-1234567890
        # Display timezone (PHP + Twig). Default UTC. Try Europe/Paris.
        APP_TIMEZONE: 'UTC'
        NAVIDROME_DB_PATH: /app/var/navidrome.db
        NAVIDROME_URL: http://host.lando.internal:4533
        NAVIDROME_USER: admin
        NAVIDROME_PASSWORD: changeme
        APP_AUTH_USER: admin
        APP_AUTH_PASSWORD: changeme
        DATABASE_URL: "sqlite:///%kernel.project_dir%/var/data.db"
        STATS_REFRESH_SCHEDULE: '0 */6 * * *'
        LIDARR_URL: ''
        LIDARR_API_KEY: ''
        LIDARR_ROOT_FOLDER_PATH: /music
        LIDARR_QUALITY_PROFILE_ID: 1
        LIDARR_METADATA_PROFILE_ID: 1
        LIDARR_MONITOR: all
        # Navidrome container management — empty = disabled.
        # Set to your Navidrome container name to enable the dashboard
        # card + start/stop buttons (requires Docker socket mount).
        NAVIDROME_CONTAINER_NAME: ''
        RUN_HISTORY_RETENTION_DAYS: '90'
        # Database backups — both schedules empty = disabled. Snapshots
        # SQLite via VACUUM INTO + gzip into var/backups/.
        DB_BACKUP_SCHEDULE: ''
        DB_BACKUP_RETENTION_DAYS: '30'
        NAVIDROME_BACKUP_SCHEDULE: ''
        NAVIDROME_BACKUP_RETENTION_DAYS: '30'
        # File de chemins consommée par un beets externe (cron côté hôte
        # qui partage le même volume). Vide = bouton « pousser dans la
        # queue beets » masqué sur /tagging/missing-mbid.
        BEETS_QUEUE_PATH: ''
        # Last.fm API key — optional. Fallback for the /lastfm/import form
        # and the app:lastfm:import CLI when --api-key is not passed.
        # Get one at https://www.last.fm/api/account/create
        LASTFM_API_KEY: ''
        # Last.fm API secret — required for /lastfm/connect and the
        # loved↔starred sync (signs auth.getSession / track.love calls).
        LASTFM_API_SECRET: ''
        # Default Last.fm username pre-filled in the import form and used
        # when the CLI argument is omitted. Leave empty to require it.
        LASTFM_USER: ''
        # Pause (in seconds) between two consecutive Last.fm API page
        # fetches. Default 10, set to 0 to disable.
        LASTFM_PAGE_DELAY_SECONDS: '10'
        # Maximum Levenshtein distance for the fuzzy fallback. 0 = disabled.
        LASTFM_FUZZY_MAX_DISTANCE: '0'
        # TTL (days) of negative match-cache entries. 0 = never expire.
        LASTFM_MATCH_CACHE_TTL_DAYS: '30'
        # Cron schedule for the loved↔starred sync (app:lastfm:sync-loved).
        # Empty = no cron line. Set e.g. '0 4 * * *' for nightly at 04:00.
        LASTFM_LOVE_SYNC_SCHEDULE: ''
        # Cron schedule for re-matching previously unmatched scrobbles
        # (app:lastfm:rematch). Empty = no cron line. Requires Navidrome stopped.
        LASTFM_REMATCH_SCHEDULE: ''
        # Local on-disk cache for album/artist cover art (proxy + cache).
        COVERS_CACHE_PATH: '/app/var/covers'
        # Homepage (gethomepage.dev) integration. Bearer token consumed
        # by the JSON endpoint /api/status. Empty = enriched mode
        # disabled, only the no-auth healthcheck mode is served.
        HOMEPAGE_API_TOKEN: ''

  cron:
    type: php:8.3
    overrides:
      environment: *app_env
      command: |
        sh -c "
          php bin/console doctrine:migrations:migrate -n --env=dev || true;
          php bin/console app:cron:dump --env=dev > /tmp/crontab;
          cat /tmp/crontab;
          /usr/local/bin/supercronic /tmp/crontab
        "
    build_as_root:
      - apk add --no-cache wget || (apt-get update && apt-get install -y wget)
      - wget -qO /usr/local/bin/supercronic https://github.com/aptible/supercronic/releases/download/v0.2.30/supercronic-linux-amd64
      - chmod +x /usr/local/bin/supercronic

tooling:
  symfony:
    service: appserver
    cmd: php bin/console
    description: Run a Symfony console command (e.g. `lando symfony cache:clear`)
  composer:
    service: appserver
    cmd: composer
  test:
    service: appserver
    cmd: vendor/bin/phpunit
  migrate:
    service: appserver
    cmd: php bin/console doctrine:migrations:migrate -n
    description: Run pending Doctrine migrations
  seed:
    service: appserver
    cmd: php bin/console app:fixtures:seed
    description: Insert example playlist definitions
  playlist-run:
    service: appserver
    cmd: php bin/console app:playlist:run
    description: Run one playlist (e.g. `lando playlist-run "Top 30 derniers jours" --dry-run`)
  cron-dump:
    service: appserver
    cmd: php bin/console app:cron:dump
    description: Print the supercronic-compatible crontab built from enabled definitions

proxy:
  appserver_nginx:
    - navidrome-tools.lndo.site
